{% extends 'base.html.twig' %}

{% block title %}Mon Profil — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen themed-page pb-12 bg-slate-50 dark:bg-slate-950">

    {# En-tête #}
    <div class="border-b border-white/10" style="background: rgba(255,255,255,0.02);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl flex items-center justify-center shadow-lg shadow-sky-500/20" style="background: linear-gradient(135deg, #0ea5e9, #3b82f6);">
                    <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white tracking-tight">Mon Profil</h1>
                    <p class="text-slate-400 text-sm mt-1">Gérez vos informations personnelles et votre photo de compte.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        {% for message in app.flashes('success') %}
            <div class="mb-6 rounded-xl p-4 flex items-center gap-3 border border-emerald-500/30" style="background: rgba(16,185,129,0.1);">
                <div class="w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center text-emerald-400 flex-shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                </div>
                <p class="text-sm font-medium text-emerald-400">{{ message }}</p>
            </div>
        {% endfor %}

        {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}

        {# --- Photo de profil --- #}
        <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
            <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                <h2 class="text-base font-bold text-white">Photo de profil</h2>
                <p class="text-sm text-slate-400 mt-0.5">Formats acceptés : JPG, PNG, WEBP. Taille max : 2 Mo.</p>
            </div>
            <div class="p-6 flex items-center gap-6">
                {# Avatar Preview #}
                <div class="relative flex-shrink-0" id="avatar-wrapper">
                    {% if app.user.photoFilename %}
                        <img id="avatar-preview"
                             src="{{ asset('uploads/profiles/' ~ app.user.photoFilename) }}"
                             alt="Photo de profil"
                             class="w-24 h-24 rounded-2xl object-cover border-2 border-indigo-500/40 shadow-lg shadow-indigo-500/20">
                    {% else %}
                        <div id="avatar-initials" class="w-24 h-24 rounded-2xl flex items-center justify-center text-3xl font-black text-white shadow-lg" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                            {{ app.user.userIdentifier|first|upper }}
                        </div>
                        <img id="avatar-preview" src="" alt="Aperçu" class="w-24 h-24 rounded-2xl object-cover border-2 border-indigo-500/40 shadow-lg shadow-indigo-500/20 hidden">
                    {% endif %}
                    {# Camera overlay button #}
                    <label for="{{ form.photoFile.vars.id }}" class="absolute -bottom-2 -right-2 w-8 h-8 rounded-full flex items-center justify-center cursor-pointer shadow-lg transition-transform hover:scale-110" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border: 2px solid #0f172a;">
                        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
                        </svg>
                    </label>
                </div>

                {# Upload Instructions #}
                <div class="flex-1">
                    <p class="text-sm font-semibold text-white mb-1">Changer votre photo</p>
                    <p class="text-xs text-slate-500 mb-3">Cliquez sur l'icône caméra pour sélectionner une image depuis votre ordinateur.</p>
                    {# Hidden actual file input #}
                    <div class="hidden">
                        {{ form_widget(form.photoFile) }}
                    </div>
                    <p id="file-chosen" class="text-xs text-indigo-400 mt-2 hidden"></p>
                </div>
            </div>
        </div>

        {# --- Informations personnelles --- #}
        <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
            <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                <h2 class="text-base font-bold text-white">Informations Personnelles</h2>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5">
                    <div>
                        {{ form_label(form.prenom, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                            </div>
                            {{ form_widget(form.prenom, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-sky-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                        </div>
                    </div>
                    <div>
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                            </div>
                            {{ form_widget(form.nom, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-sky-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                        </div>
                    </div>
                    <div>
                        {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            </div>
                            {{ form_widget(form.email, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-sky-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                        </div>
                    </div>
                    <div>
                        {{ form_label(form.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                            </div>
                            {{ form_widget(form.telephone, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-sky-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# --- Sécurité --- #}
        <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
            <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                <h2 class="text-base font-bold text-white">Sécurité</h2>
                <p class="text-sm text-slate-400 mt-0.5">Laissez vide pour ne pas modifier le mot de passe actuel.</p>
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5">
                <div>
                    {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                        </div>
                        {{ form_widget(form.plainPassword.first, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-sky-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                    </div>
                    {{ form_errors(form.plainPassword.first) }}
                </div>
                <div>
                    {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                        </div>
                        {{ form_widget(form.plainPassword.second, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-sky-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                    </div>
                </div>
            </div>
        </div>

        {# Bouton Enregistrer #}
        <div class="flex justify-end">
            <button type="submit" class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-white transition-all shadow-lg shadow-sky-500/20 hover:shadow-sky-500/40 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #0ea5e9, #3b82f6);">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0120.25 6v12A2.25 2.25 0 0118 20.25H6A2.25 2.25 0 013.75 18V6A2.25 2.25 0 016 3.75h1.5m9 0h-9" />
                </svg>
                Enregistrer les modifications
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const input = document.getElementById('{{ form.photoFile.vars.id }}');
    const preview = document.getElementById('avatar-preview');
    const initials = document.getElementById('avatar-initials');
    const fileChosen = document.getElementById('file-chosen');

    input.addEventListener('change', function () {
        if (this.files && this.files[0]) {
            const file = this.files[0];
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                if (initials) initials.classList.add('hidden');
            };
            reader.readAsDataURL(file);
            fileChosen.textContent = 'Fichier sélectionné : ' + file.name;
            fileChosen.classList.remove('hidden');
        }
    });
});
</script>
{% endblock %}
