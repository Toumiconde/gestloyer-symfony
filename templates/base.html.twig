                    const res = await fetch("{{ path('app_notifications_poll') }}", { headers: { 'Accept': 'application/json' }});
                    if (!res.ok) return;
                    const data = await res.json();
                    const count = Number(data.count || 0);
                    if (count > 0) {
                        badge.textContent = String(count);
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                    const latest = Array.isArray(data.latest) ? data.latest : [];
                    if (latest.length === 0) {
                        items.innerHTML = '<div class="px-3 py-6 text-center text-xs text-slate-500">Aucune nouvelle notification.</div>';
                        return;
                    }
                    items.innerHTML = latest.map((n) => {
                        let iconBg = 'bg-blue-500/10 text-blue-500';
                        let iconSvg = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>';
                        
