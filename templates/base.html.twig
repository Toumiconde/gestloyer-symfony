<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}GESTLOYER - Plateforme de Gestion Locative{% endblock %}</title>
    <meta name="description" content="GESTLOYER — Solution professionnelle de gestion locative">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <script src="https://cdn.tailwindcss.com"></script>
        <script>tailwind.config = { darkMode: 'class' };</script>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        <style>
            body { font-family: 'Inter', sans-serif; }
            .glass-panel { background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2); }
            .nav-link-active { color: #a5b4fc !important; border-bottom: 2px solid #6366f1; }
            .sidebar-icon { transition: all 0.2s ease; }
            .nav-link:hover .sidebar-icon { transform: scale(1.1); }
        </style>
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

    <script>
        (function(){
            const t = localStorage.getItem('theme');
            if (t === 'light') {
                document.documentElement.classList.remove('dark');
            } else if (t === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            }
        })();
    </script>
</head>
<body class="h-full flex flex-col bg-gray-50 dark:bg-slate-900">

    {% if app.user %}
    <nav class="border-b border-slate-200 dark:border-slate-800/60 shadow-xl z-50 bg-white dark:bg-slate-900">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-16 items-center justify-between">

                <!-- Logo + Nav Links -->
                <div class="flex items-center gap-8">
                    <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2.5 flex-shrink-0">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" />
                            </svg>
                        </div>
                        <span class="text-xl font-bold text-slate-900 dark:text-white tracking-tight">GEST<span class="text-indigo-400">LOYER</span></span>
                    </a>

                    <div class="hidden sm:flex sm:items-center sm:gap-1">
                        <a href="{{ path('app_dashboard') }}" class="nav-link group flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all duration-150">
                            <svg class="sidebar-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                            </svg>
                            {{ 'menu.dashboard'|trans }}
                        </a>
                        <a href="{{ path('app_bien_index') }}" class="nav-link group flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all duration-150">
                            <svg class="sidebar-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" />
                            </svg>
                            {{ 'menu.patrimoine'|trans }}
                        </a>
                        <a href="{{ path('app_contrat_index') }}" class="nav-link group flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all duration-150">
                            <svg class="sidebar-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                            </svg>
                            {{ 'menu.contrats'|trans }}
                        </a>
                        <a href="{{ path('app_paiement_index') }}" class="nav-link group flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all duration-150">
                            <svg class="sidebar-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                            </svg>
                            {{ 'menu.paiements'|trans }}
                        </a>
                        <a href="{{ path('app_incident_index') }}" class="nav-link group flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all duration-150">
                            <svg class="sidebar-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                            </svg>
                            {{ 'menu.incidents'|trans }}
                        </a>

                        {% if is_granted('ROLE_ADMIN') %}
                        <div class="relative" id="admin-menu-root">
                            <button id="admin-menu-trigger" type="button"
                                    class="nav-link group inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-indigo-300 bg-indigo-500/10 border border-indigo-500/30 hover:bg-indigo-500/20 transition-all duration-150">
                                <svg class="sidebar-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                                </svg>
                                Admin
                                <svg class="w-4 h-4 text-indigo-200/80" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>
                            <div id="admin-menu-panel" class="hidden absolute left-0 mt-2 w-64 rounded-2xl border border-slate-200 dark:border-white/10 bg-white dark:bg-slate-900 shadow-2xl p-2 z-50">
                                <a href="{{ path('app_admin_index') }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Panel Admin</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">/admin</span>
                                </a>
                                <a href="{{ path('app_admin_parametres') }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Paramètres</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">/admin/parametres</span>
                                </a>
                                <div class="my-1 h-px bg-slate-100 dark:bg-white/10"></div>
                                <a href="{{ path('app_admin_users') }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Tous les utilisateurs</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">/admin/utilisateurs</span>
                                </a>
                                <a href="{{ path('app_admin_users', {role: 'ROLE_GESTIONNAIRE'}) }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Gestionnaires</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">ROLE_GESTIONNAIRE</span>
                                </a>
                                <a href="{{ path('app_admin_users', {role: 'ROLE_COMPTABLE'}) }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Comptables</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">ROLE_COMPTABLE</span>
                                </a>
                                <a href="{{ path('app_admin_users', {role: 'ROLE_PROPRIETAIRE'}) }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Propriétaires</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">ROLE_PROPRIETAIRE</span>
                                </a>
                                <a href="{{ path('app_admin_users', {role: 'ROLE_LOCATAIRE'}) }}" class="flex items-center justify-between px-3 py-2 rounded-xl text-sm text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5">
                                    <span>Locataires</span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400">ROLE_LOCATAIRE</span>
                                </a>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>

                <!-- User Info + Actions -->
                <div class="hidden sm:flex sm:items-center gap-2">

                    {% if is_granted('ROLE_ADMIN') %}
                    <div class="relative" id="notif-root">
                        <button id="notif-trigger" type="button"
                                class="relative flex items-center justify-center w-9 h-9 rounded-xl border border-slate-200 dark:border-white/10 hover:bg-slate-100 dark:hover:bg-white/5 transition-all bg-white dark:bg-slate-800">
                            <svg class="w-4 h-4 text-slate-700 dark:text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                            </svg>
                            <span id="notif-badge" class="hidden absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full text-[11px] font-bold text-white flex items-center justify-center" style="background: #ef4444;">0</span>
                        </button>
                        <div id="notif-panel" class="hidden absolute right-0 mt-2 w-96 rounded-2xl border border-slate-200 dark:border-white/10 shadow-2xl p-2 z-50 bg-white dark:bg-slate-800">
                            <div class="flex items-center justify-between px-2 py-2">
                                <div class="text-sm font-semibold text-slate-900 dark:text-white">Notifications</div>
                                <form id="notif-mark-form" method="POST" action="{{ path('app_admin_notifications_mark_seen') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_notifications_seen') }}">
                                    <button type="submit" class="text-xs text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">Tout marquer comme vu</button>
                                </form>
                            </div>
                            <div id="notif-items" class="max-h-80 overflow-auto"></div>
                            <div class="px-2 py-2">
                                <a href="{{ path('app_admin_parametres') }}#section-historique" class="text-xs text-indigo-400 hover:text-indigo-300">Ouvrir l'historique →</a>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    {% if is_granted('ROLE_PROPRIETAIRE') %}
                    <div class="relative" id="owner-notif-root">
                        <button id="owner-notif-trigger" type="button"
                                class="relative flex items-center justify-center w-9 h-9 rounded-xl border border-slate-200 dark:border-white/10 hover:bg-slate-100 dark:hover:bg-white/5 transition-all bg-white dark:bg-slate-800">
                            <svg class="w-4 h-4 text-slate-700 dark:text-slate-300" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                            </svg>
                            <span id="owner-notif-badge" class="hidden absolute -top-1.5 -right-1.5 min-w-5 h-5 px-1.5 rounded-full text-[10px] font-bold text-white flex items-center justify-center animate-pulse bg-rose-500 shadow-md shadow-rose-500/30">0</span>
                        </button>
                        <div id="owner-notif-panel" class="hidden absolute right-0 mt-2 w-96 rounded-2xl border border-slate-200 dark:border-white/10 shadow-2xl p-2 z-50 bg-white dark:bg-slate-800">
                            <div class="flex items-center justify-between px-2 py-2 border-b border-slate-100 dark:border-white/5 pb-2">
                                <div class="text-sm font-semibold text-slate-900 dark:text-white">Notifications</div>
                                <form id="owner-notif-mark-form" method="POST" action="{{ path('app_notifications_mark_seen') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('notifications_seen') }}">
                                    <button type="submit" class="text-xs text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white">Tout marquer comme vu</button>
                                </form>
                            </div>
                            <div id="owner-notif-items" class="max-h-80 overflow-auto py-1 flex flex-col gap-1"></div>
                        </div>
                    </div>
                    {% endif %}

                    {# ── Bouton Thème ── #}
                    <button id="global-theme-toggle" type="button"
                            class="flex items-center justify-center w-9 h-9 rounded-xl border border-slate-200 dark:border-white/10 hover:bg-slate-100 dark:hover:bg-white/5 transition-all bg-white dark:bg-slate-800"
                            title="Changer le thème">
                        <svg id="global-sun-icon" class="w-4 h-4 text-amber-500 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                        </svg>
                        <svg id="global-moon-icon" class="w-4 h-4 text-slate-400 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                        </svg>
                    </button>

                    {# ── Bouton Langue FR/EN ── #}
                    <div class="flex items-center rounded-xl border border-slate-200 dark:border-white/10 bg-white dark:bg-slate-800 overflow-hidden">
                        <a href="{{ path('app_change_locale', {locale: 'fr'}) }}"
                           class="px-2.5 py-1.5 text-xs font-bold transition-colors {{ app.request.locale == 'fr' ? 'bg-indigo-600 text-white' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5' }}">
                            FR
                        </a>
                        <div class="w-px h-4 bg-slate-200 dark:bg-white/10"></div>
                        <a href="{{ path('app_change_locale', {locale: 'en'}) }}"
                           class="px-2.5 py-1.5 text-xs font-bold transition-colors {{ app.request.locale == 'en' ? 'bg-indigo-600 text-white' : 'text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-white/5' }}">
                            EN
                        </a>
                    </div>

                    {# ── Profil ── #}
                    <a href="{{ path('app_profile') }}" class="flex items-center gap-2.5 px-3 py-1.5 rounded-xl border border-slate-200 dark:border-white/10 hover:bg-slate-100 dark:hover:bg-white/5 transition-all group bg-white dark:bg-slate-800">
                        {% if app.user.photoFilename %}
                            <img src="{{ asset('uploads/profiles/' ~ app.user.photoFilename) }}"
                                 alt="Photo de profil"
                                 class="w-7 h-7 rounded-full object-cover shadow-sm border border-indigo-500/40">
                        {% else %}
                            <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold text-white shadow-sm" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                                {{ app.user.userIdentifier|first|upper }}
                            </div>
                        {% endif %}
                        <div>
                            <div class="text-xs text-slate-900 dark:text-white font-medium leading-tight">{{ app.user.userIdentifier }}</div>
                            <div class="text-[10px] font-semibold mt-0.5
                                {% if is_granted('ROLE_ADMIN') %}text-indigo-400
                                {% elseif is_granted('ROLE_GESTIONNAIRE') %}text-blue-400
                                {% elseif is_granted('ROLE_COMPTABLE') %}text-emerald-400
                                {% elseif is_granted('ROLE_PROPRIETAIRE') %}text-orange-400
                                {% else %}text-slate-400{% endif %}">
                                {{ app.user.roles[0]|replace({'ROLE_': ''}) }}
                            </div>
                        </div>
                    </a>

                    {# ── Déconnexion ── #}
                    <a href="{{ path('app_logout') }}"
                       class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-rose-600 dark:hover:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-500/10 transition-all border border-transparent hover:border-rose-200 dark:hover:border-rose-500/20"
                       title="{{ 'menu.logout'|trans }}">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
                        </svg>
                        {{ 'menu.logout'|trans }}
                    </a>
                </div>

            </div>
        </div>
    </nav>
    {% endif %}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Admin dropdown
            const adminRoot = document.getElementById('admin-menu-root');
            const adminTrigger = document.getElementById('admin-menu-trigger');
            const adminPanel = document.getElementById('admin-menu-panel');
            if (adminRoot && adminTrigger && adminPanel) {
                adminTrigger.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    adminPanel.classList.toggle('hidden');
                });
                document.addEventListener('click', function (e) {
                    if (!adminRoot.contains(e.target)) adminPanel.classList.add('hidden');
                });
            }

            // Thème global
            const toggle = document.getElementById('global-theme-toggle');
            const sunIcon = document.getElementById('global-sun-icon');
            const moonIcon = document.getElementById('global-moon-icon');

            function updateThemeIcons() {
                if (!sunIcon || !moonIcon) return;
                const isDark = document.documentElement.classList.contains('dark');
                sunIcon.classList.toggle('hidden', !isDark);
                moonIcon.classList.toggle('hidden', isDark);
            }

            toggle?.addEventListener('click', function () {
                const isDark = document.documentElement.classList.contains('dark');
                if (isDark) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                }
                updateThemeIcons();
            });

            updateThemeIcons();
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const root = document.getElementById('notif-root');
            const trigger = document.getElementById('notif-trigger');
            const panel = document.getElementById('notif-panel');
            const badge = document.getElementById('notif-badge');
            const items = document.getElementById('notif-items');
            const markForm = document.getElementById('notif-mark-form');
            if (!root || !trigger || !panel || !badge || !items) return;

            async function poll() {
                if (!panel.classList.contains('hidden')) return;
                try {
                    const res = await fetch("{{ path('app_admin_notifications_poll') }}", { headers: { 'Accept': 'application/json' }});
                    if (!res.ok) return;
                    const data = await res.json();
                    const count = Number(data.count || 0);
                    if (count > 0) {
                        badge.textContent = String(count);
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                    const latest = Array.isArray(data.latest) ? data.latest : [];
                    if (latest.length === 0) {
                        items.innerHTML = '<div class="px-2 py-6 text-center text-sm text-slate-500">Aucune nouvelle notification.</div>';
                        return;
                    }
                    items.innerHTML = latest.map((n) => {
                        const href = "{{ path('app_admin_history_show', {id: 0}) }}".replace('/0', '/' + String(n.id));
                        return `
                            <a href="${href}" class="block px-2 py-2 rounded-xl hover:bg-slate-100 dark:hover:bg-white/5 transition">
                                <div class="flex items-center justify-between gap-3">
                                    <div class="text-sm font-semibold text-slate-900 dark:text-white">${n.action || 'EVENT'}</div>
                                    <div class="text-[11px] text-slate-400">${n.createdAt || ''}</div>
                                </div>
                                <div class="text-xs text-slate-500 mt-0.5">${n.actorEmail || ''}</div>
                                ${n.details ? `<div class="text-xs text-slate-400 mt-1">${n.details}</div>` : ''}
                            </a>`;
                    }).join('');
                } catch (e) {}
            }

            function open() {
                panel.classList.remove('hidden');
                badge.classList.add('hidden');
                if (markForm) {
                    const fd = new FormData(markForm);
                    fetch(markForm.action, { method: 'POST', body: fd }).catch(() => {});
                }
            }

            function close() {
                if (!panel.classList.contains('hidden')) {
                    panel.classList.add('hidden');
                    poll();
                }
            }

            trigger.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                panel.classList.contains('hidden') ? open() : close();
            });

            document.addEventListener('click', function (e) {
                if (!root.contains(e.target)) close();
            });

            markForm?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const fd = new FormData(markForm);
                await fetch(markForm.action, { method: 'POST', body: fd }).catch(() => {});
                close();
            });

            poll();
            setInterval(poll, 15000);
        });
    </script>

    {% if is_granted('ROLE_PROPRIETAIRE') %}
    <script>
