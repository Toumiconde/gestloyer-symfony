                        } else if (n.type === 'incident') {
                            iconBg = 'bg-rose-500/10 text-rose-500';
                            iconSvg = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>';
                        } else if (n.type === 'devis') {
                            iconBg = 'bg-purple-500/10 text-purple-500';
                            iconSvg = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>';
                        }
                        return `
                            <div class="flex gap-3 px-3 py-2.5 rounded-xl hover:bg-slate-50 dark:hover:bg-white/5 transition duration-150 border border-transparent hover:border-slate-100 dark:hover:border-white/5">
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${iconBg}">
                                    ${iconSvg}
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center justify-between gap-2">
                                        <p class="text-xs font-bold text-slate-900 dark:text-white truncate">${n.title || 'Notification'}</p>
                                        <span class="text-[9px] text-slate-400 dark:text-slate-500 font-medium whitespace-nowrap">${n.createdAt || ''}</span>
                                    </div>
                                    <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-0.5 leading-relaxed break-words">${n.message || ''}</p>
                                </div>
                            </div>`;
                    }).join('');
                } catch (e) {}
            }

            function open() {
                panel.classList.remove('hidden');
                badge.classList.add('hidden');
                if (markForm) {
                    const fd = new FormData(markForm);
                    fetch(markForm.action, { method: 'POST', body: fd }).catch(() => {});
                }
            }

            function close() {
                if (!panel.classList.contains('hidden')) {
                    panel.classList.add('hidden');
                    poll();
                }
            }

            trigger.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                panel.classList.contains('hidden') ? open() : close();
            });

            document.addEventListener('click', function (e) {
                if (!root.contains(e.target)) close();
            });

            markForm?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const fd = new FormData(markForm);
                await fetch(markForm.action, { method: 'POST', body: fd }).catch(() => {});
                close();
            });

            poll();
            setInterval(poll, 15000);
        });
    </script>
    {% endif %}

    <main class="flex-1">
        <div class="{% if app.user %}mx-auto max-w-7xl{% else %}w-full{% endif %} py-6 sm:px-6 lg:px-8">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                <div class="mb-4 rounded-xl p-4 flex items-start gap-3 shadow-sm
                    {% if label == 'success' %}bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30
                    {% else %}bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/30{% endif %}">
                    <div class="flex-shrink-0 mt-0.5">
                        {% if label == 'success' %}
                        <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        {% else %}
                        <svg class="w-5 h-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
                        {% endif %}
                    </div>
                    <p class="text-sm font-medium {% if label == 'success' %}text-emerald-800 dark:text-emerald-300{% else %}text-rose-800 dark:text-rose-300{% endif %}">{{ message }}</p>
                </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </main>

</body>
