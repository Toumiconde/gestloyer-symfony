{% extends 'base.html.twig' %}

{% block title %}Dashboard Analytique | GESTLOYER{% endblock %}

{% block body %}
{% set currentYear = "now"|date('Y') %}
<div class="min-h-screen bg-gray-50 dark:bg-slate-900 pb-12">
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# ── HEADER ──────────────────────────────────────────────────────── #}
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">📊 Tableau de Bord Analytique</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">Vue globale du patrimoine — {{ currentYear }}</p>
        </div>
        <div class="flex gap-3">
            {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_admin_parametres') }}" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 dark:text-slate-300 bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 transition shadow-sm">
                ⚙️ Paramètres
            </a>
            {% endif %}
            <a href="{{ path('app_bien_new') }}" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-600/20">
                + Nouveau Bien
            </a>
        </div>
    </div>

    {# ── KPIs PRINCIPAUX ─────────────────────────────────────────────── #}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

        {# Taux d'occupation #}
        <div class="col-span-2 lg:col-span-1 bg-gradient-to-br from-indigo-500 to-indigo-700 rounded-2xl p-5 text-white shadow-lg shadow-indigo-500/20">
            <p class="text-xs font-bold uppercase tracking-wider text-indigo-200 mb-1">Taux d'occupation</p>
            <p class="text-4xl font-black mb-2">{{ stats.taux_occupation }}%</p>
            <div class="w-full bg-indigo-400/40 rounded-full h-2 mb-2">
                <div class="bg-white rounded-full h-2 transition-all" style="width: {{ stats.taux_occupation }}%"></div>
            </div>
            <p class="text-xs text-indigo-200">{{ stats.biens_occupes }} occupés / {{ stats.biens_total }} biens au total</p>
        </div>

        {# Loyers Encaissés #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Loyers Encaissés</p>
                <span class="w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center text-base">💰</span>
            </div>
            <p class="text-2xl font-black text-slate-900 dark:text-white">{{ (stats.loyers_encaisses / 1000000)|number_format(1, ',') }}M</p>
            <p class="text-xs text-emerald-600 dark:text-emerald-400 font-medium mt-1">GNF validés</p>
        </div>

        {# Impayés #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Impayés</p>
                <span class="w-8 h-8 rounded-lg bg-rose-100 dark:bg-rose-500/20 flex items-center justify-center text-base">⚠️</span>
            </div>
            <p class="text-2xl font-black text-rose-600 dark:text-rose-400">{{ (stats.impayes / 1000000)|number_format(1, ',') }}M</p>
            <p class="text-xs text-rose-500 dark:text-rose-400 font-medium mt-1">GNF en retard</p>
        </div>

        {# Incidents ouverts #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Incidents</p>
                <span class="w-8 h-8 rounded-lg bg-orange-100 dark:bg-orange-500/20 flex items-center justify-center text-base">🔧</span>
            </div>
            <p class="text-2xl font-black text-slate-900 dark:text-white">{{ stats.incidents_ouverts }}</p>
            <p class="text-xs text-orange-500 dark:text-orange-400 font-medium mt-1">en cours de traitement</p>
        </div>

    </div>

    {# ── RÉPARTITION DES BIENS ────────────────────────────────────────── #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">

        {# Répartition statuts biens #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
            <h2 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wide mb-4">Répartition du Parc Immobilier</h2>
            <div class="flex items-center justify-center mb-4">
                <canvas id="biensChart" class="max-w-[180px]"></canvas>
            </div>
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400"><span class="w-3 h-3 rounded-full bg-emerald-500"></span> Occupés</span>
                    <span class="text-sm font-bold text-slate-900 dark:text-white">{{ stats.biens_occupes }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400"><span class="w-3 h-3 rounded-full bg-blue-500"></span> Vacants</span>
                    <span class="text-sm font-bold text-slate-900 dark:text-white">{{ stats.biens_vacants }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400"><span class="w-3 h-3 rounded-full bg-orange-500"></span> En Travaux</span>
                    <span class="text-sm font-bold text-slate-900 dark:text-white">{{ stats.biens_travaux }}</span>
                </div>
            </div>
        </div>

        {# Incidents par priorité #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
            <h2 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wide mb-4">Incidents par Priorité</h2>
            <div class="flex items-center justify-center mb-4">
                <canvas id="incidentsChart" class="max-w-[180px]"></canvas>
            </div>
            <div class="space-y-2">
                {% set p_labels = {'URGENT': {color: 'bg-rose-500', label: 'Urgent'}, 'NORMAL': {color: 'bg-amber-500', label: 'Normal'}, 'FAIBLE': {color: 'bg-emerald-500', label: 'Faible'}} %}
                {% for row in incidents_by_priorite %}
                {% set pl = p_labels[row.priorite.value] ?? {color: 'bg-slate-400', label: row.priorite.value} %}
                <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
                        <span class="w-3 h-3 rounded-full {{ pl.color }}"></span> {{ pl.label }}
                    </span>
                    <span class="text-sm font-bold text-slate-900 dark:text-white">{{ row.total }}</span>
                </div>
                {% else %}
                <p class="text-sm text-slate-400 text-center py-4">Aucun incident ouvert 🎉</p>
                {% endfor %}
            </div>
        </div>

        {# Derniers contrats #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm">
            <h2 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wide mb-4">Derniers Contrats</h2>
            <div class="space-y-3">
                {% for contrat in derniers_contrats %}
                <a href="{{ path('app_contrat_show', {id: contrat.id}) }}" class="block p-3 rounded-xl bg-slate-50 dark:bg-slate-700/30 hover:bg-slate-100 dark:hover:bg-slate-700/50 transition">
                    <div class="flex items-center justify-between mb-1">
                        <p class="text-xs font-bold text-slate-900 dark:text-white truncate">{{ contrat.bien.nom }}</p>
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold
                            {% if contrat.statut.value == 'ACTIF' %}bg-emerald-100 text-emerald-700{% else %}bg-slate-100 text-slate-600{% endif %}">
                            {{ contrat.statut.value }}
                        </span>
                    </div>
                    <p class="text-xs text-slate-500">{{ contrat.locataire.nom }} {{ contrat.locataire.prenom }}</p>
                    <p class="text-xs text-indigo-600 dark:text-indigo-400 font-bold">{{ contrat.loyerMensuel|number_format(0,',',' ') }} GNF/mois</p>
                </a>
                {% else %}
                <p class="text-sm text-slate-400 text-center py-4">Aucun contrat</p>
                {% endfor %}
            </div>
        </div>

    </div>

    {# ── GRAPHIQUE REVENUS 12 MOIS ────────────────────────────────────── #}
    <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm mb-8">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h2 class="text-base font-bold text-slate-900 dark:text-white">Évolution des Revenus {{ currentYear }}</h2>
                <p class="text-xs text-slate-500 mt-0.5">Loyers encaissés mois par mois</p>
            </div>
            <span class="px-2.5 py-1 rounded-full bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 text-xs font-bold">Données réelles</span>
        </div>
        <div class="h-56">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    {# ── TABLEAUX ANALYTIQUES ─────────────────────────────────────────── #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        {# Loyers impayés par locataire #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700 flex items-center justify-between">
                <h2 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wide">⚠️ Impayés par Locataire</h2>
                <a href="{{ path('app_paiement_index', {statut: 'EN_ATTENTE'}) }}" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium">Voir tout</a>
            </div>
            <div class="divide-y divide-slate-100 dark:divide-slate-700/50">
                {% for row in impayes_par_locataire %}
                {% set pct = stats.impayes > 0 ? (row.total_impaye / stats.impayes * 100)|round : 0 %}
                <div class="px-6 py-3">
                    <div class="flex items-center justify-between mb-1">
                        <div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ row.nom }} {{ row.prenom }}</p>
                            <p class="text-xs text-slate-400">{{ row.email }} · {{ row.nb_retards }} mois en retard</p>
                        </div>
                        <p class="text-sm font-black text-rose-600 dark:text-rose-400 ml-4 flex-shrink-0">{{ (row.total_impaye / 1000)|number_format(0,',',' ') }}k GNF</p>
                    </div>
                    <div class="w-full bg-slate-100 dark:bg-slate-700 rounded-full h-1.5">
                        <div class="bg-rose-500 rounded-full h-1.5" style="width: {{ pct }}%"></div>
                    </div>
                </div>
                {% else %}
                <div class="px-6 py-12 text-center">
                    <p class="text-4xl mb-2">🎉</p>
                    <p class="text-sm text-slate-500">Aucun impayé en cours !</p>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Revenus par propriétaire #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700 flex items-center justify-between">
                <h2 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wide">💼 Revenus par Propriétaire</h2>
                <a href="{{ path('app_reversement_index') }}" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium">Reversements</a>
            </div>
            <div class="divide-y divide-slate-100 dark:divide-slate-700/50">
                {% set max_revenu = revenus_par_proprietaire|length > 0 ? revenus_par_proprietaire|first.total_revenu : 1 %}
                {% for row in revenus_par_proprietaire %}
                {% set pct = max_revenu > 0 ? (row.total_revenu / max_revenu * 100)|round : 0 %}
                <div class="px-6 py-3">
                    <div class="flex items-center justify-between mb-1">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-500/20 flex items-center justify-center text-indigo-600 font-bold text-sm">
                                {{ row.nom|first|upper }}
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-900 dark:text-white">{{ row.prenom }} {{ row.nom }}</p>
                                <p class="text-xs text-slate-400">{{ row.nb_biens }} bien(s)</p>
                            </div>
                        </div>
                        <p class="text-sm font-black text-emerald-600 dark:text-emerald-400 ml-4 flex-shrink-0">{{ (row.total_revenu / 1000)|number_format(0,',',' ') }}k GNF</p>
                    </div>
                    <div class="w-full bg-slate-100 dark:bg-slate-700 rounded-full h-1.5">
                        <div class="bg-indigo-500 rounded-full h-1.5" style="width: {{ pct }}%"></div>
                    </div>
                </div>
                {% else %}
                <div class="px-6 py-12 text-center">
                    <p class="text-4xl mb-2">📊</p>
                    <p class="text-sm text-slate-500">Aucun reversement enregistré.</p>
                </div>
                {% endfor %}
            </div>
        </div>

    </div>

</div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
    const labelColor = isDark ? '#94a3b8' : '#64748b';

    // Graphique Revenus 12 mois
    const ctxRev = document.getElementById('revenueChart').getContext('2d');
    const grad = ctxRev.createLinearGradient(0, 0, 0, 220);
    grad.addColorStop(0, 'rgba(99,102,241,0.35)');
    grad.addColorStop(1, 'rgba(99,102,241,0)');
    new Chart(ctxRev, {
        type: 'line',
        data: {
            labels: {{ revenus_labels|json_encode|raw }},
            datasets: [{
                label: 'Revenus (GNF)',
                data: {{ revenus_values|json_encode|raw }},
                borderColor: '#6366f1', backgroundColor: grad,
                borderWidth: 2.5, pointBackgroundColor: '#6366f1', pointRadius: 4,
                pointHoverRadius: 6, fill: true, tension: 0.4
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: {
                backgroundColor: '#1e293b', padding: 10,
                callbacks: { label: ctx => new Intl.NumberFormat('fr-FR').format(ctx.parsed.y) + ' GNF' }
            }},
            scales: {
                y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: labelColor, callback: v => (v/1000000).toFixed(1)+'M' } },
                x: { grid: { display: false }, ticks: { color: labelColor } }
            }
        }
    });

    // Graphique Répartition Biens
    const ctxBiens = document.getElementById('biensChart').getContext('2d');
    new Chart(ctxBiens, {
        type: 'doughnut',
        data: {
            labels: ['Occupés', 'Vacants', 'En Travaux'],
            datasets: [{ data: [{{ stats.biens_occupes }}, {{ stats.biens_vacants }}, {{ stats.biens_travaux }}],
                backgroundColor: ['#10b981', '#3b82f6', '#f97316'],
                borderWidth: 0, hoverOffset: 4 }]
        },
        options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false } }, cutout: '72%' }
    });

    // Graphique Incidents
    const ctxInc = document.getElementById('incidentsChart').getContext('2d');
    const incData = {{ incidents_by_priorite|map(r => r.total)|json_encode|raw }};
    const incLabels = {{ incidents_by_priorite|map(r => r.priorite.value)|json_encode|raw }};
    new Chart(ctxInc, {
        type: 'doughnut',
        data: {
            labels: incLabels.length ? incLabels : ['Aucun'],
            datasets: [{ data: incData.length ? incData : [1],
                backgroundColor: incData.length ? ['#ef4444', '#f59e0b', '#10b981'] : ['#e2e8f0'],
                borderWidth: 0, hoverOffset: 4 }]
        },
        options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false } }, cutout: '72%' }
    });
});
</script>
{% endblock %}