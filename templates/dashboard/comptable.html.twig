{% extends 'base.html.twig' %}

{% block title %}Dashboard Comptable — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen pb-12 bg-gray-50 dark:bg-slate-900 transition-colors duration-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# ── HEADER ─────────────────────────────────────────────────────────── #}
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Espace Comptable</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1">
                    Bonjour {{ app.user.prenom ?? app.user.userIdentifier }} — voici l'état financier du jour.
                </p>
            </div>
            <a href="{{ path('app_paiement_index') }}"
               class="inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-600/20 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                Tous les paiements
            </a>
        </div>

        {# ── KPIs ────────────────────────────────────────────────────────────── #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

            {# Paiements en attente #}
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-amber-200 dark:border-amber-500/30 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">À valider</p>
                    <div class="w-11 h-11 rounded-full bg-amber-100 dark:bg-amber-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-black text-slate-900 dark:text-white mb-1">{{ stats.paiements_en_attente }}</p>
                <p class="text-sm text-amber-600 dark:text-amber-400 font-semibold">
                    {{ stats.montant_en_attente|number_format(0, ',', ' ') }} GNF à encaisser
                </p>
            </div>

            {# Paiements validés #}
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-emerald-200 dark:border-emerald-500/30 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Encaissés</p>
                    <div class="w-11 h-11 rounded-full bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-black text-slate-900 dark:text-white mb-1">{{ stats.paiements_valides }}</p>
                <p class="text-sm text-emerald-600 dark:text-emerald-400 font-semibold">
                    {{ stats.montant_valides|number_format(0, ',', ' ') }} GNF encaissés
                </p>
            </div>

            {# Incidents ouverts #}
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-orange-200 dark:border-orange-500/30 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Incidents ouverts</p>
                    <div class="w-11 h-11 rounded-full bg-orange-100 dark:bg-orange-500/20 flex items-center justify-center">
                        <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        </svg>
                    </div>
                </div>
                <p class="text-3xl font-black text-slate-900 dark:text-white mb-1">{{ stats.incidents_en_cours }}</p>
                <a href="{{ path('app_incident_index') }}"
                   class="text-sm text-orange-600 dark:text-orange-400 font-semibold hover:underline">
                    Voir les incidents →
                </a>
            </div>

        </div>

        {# ── LISTE DES PAIEMENTS EN ATTENTE ──────────────────────────────────── #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700/60 shadow-sm overflow-hidden">

            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 dark:border-slate-700/50">
                <div>
                    <h2 class="text-lg font-bold text-slate-900 dark:text-white">Paiements en attente de validation</h2>
                    <p class="text-xs text-slate-400 mt-0.5">{{ stats.paiements_en_attente }} paiement{{ stats.paiements_en_attente > 1 ? 's' : '' }} à traiter</p>
                </div>
                {% if stats.paiements_en_attente > 0 %}
                <a href="{{ path('app_paiement_index', {statut: 'EN_ATTENTE'}) }}"
                   class="text-sm font-medium text-indigo-600 hover:text-indigo-700 dark:text-indigo-400">
                    Voir tout →
                </a>
                {% endif %}
            </div>

            {% if paiements_en_attente is empty %}
            <div class="py-16 text-center">
                <div class="w-14 h-14 rounded-2xl bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <p class="text-base font-semibold text-slate-900 dark:text-white">Tout est à jour !</p>
                <p class="text-sm text-slate-400 mt-1">Aucun paiement en attente de validation.</p>
            </div>
            {% else %}
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/80">
                        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Mois</th>
                        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Locataire</th>
                        <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Bien</th>
                        <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Montant dû</th>
                        <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Versé</th>
                        <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50">
                    {% for paiement in paiements_en_attente %}
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/20 transition">
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900 dark:text-white whitespace-nowrap">
                            {{ paiement.mois ? paiement.mois|date('M Y')|upper : '—' }}
                        </td>
                        <td class="px-6 py-4">
                            {% if paiement.contrat %}
                            <p class="text-sm font-medium text-slate-900 dark:text-white">
                                {{ paiement.contrat.locataire.nom ?? '' }} {{ paiement.contrat.locataire.prenom ?? '' }}
                            </p>
                            <p class="text-xs text-slate-400">{{ paiement.contrat.locataire.email }}</p>
                            {% else %}
                            <span class="text-sm text-slate-400">—</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                            {{ paiement.contrat and paiement.contrat.bien ? paiement.contrat.bien.nom : '—' }}
                        </td>
                        <td class="px-6 py-4 text-right text-sm font-semibold text-slate-900 dark:text-white whitespace-nowrap">
                            {{ paiement.montantDu|number_format(0, ',', ' ') }} GNF
                        </td>
                        <td class="px-6 py-4 text-right text-sm font-medium text-emerald-600 dark:text-emerald-400 whitespace-nowrap">
                            {{ paiement.montantVerse|number_format(0, ',', ' ') }} GNF
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('app_paiement_show', {id: paiement.id}) }}"
                                   class="text-xs px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-600 transition">
                                    Détail
                                </a>
                                <form method="POST" action="{{ path('app_paiement_valider', {id: paiement.id}) }}" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ paiement.id) }}">
                                    <button type="submit"
                                            class="text-xs px-3 py-1.5 rounded-lg bg-emerald-600 text-white font-semibold hover:bg-emerald-700 shadow-sm shadow-emerald-600/20 transition">
                                        ✓ Valider
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            {% if stats.paiements_en_attente > paiements_en_attente|length %}
            <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-700/50 text-center">
                <a href="{{ path('app_paiement_index', {statut: 'EN_ATTENTE'}) }}"
                   class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:underline">
                    Voir les {{ stats.paiements_en_attente - paiements_en_attente|length }} autres →
                </a>
            </div>
            {% endif %}

            {% endif %}

        </div>

    </div>
</div>
{% endblock %}
