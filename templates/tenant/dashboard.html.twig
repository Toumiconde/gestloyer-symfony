{% extends 'base_tenant.html.twig' %}

{% block title %}Tableau de Bord Locataire{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .glass {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .gradient-header {
            background: linear-gradient(135deg, #14b8a6, #10b981);
        }
        .nav-link {
            color: #fff;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: background 0.3s;
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.2);
        }
    </style>
{% endblock %}

{% block tenant_content %}
<div class="gradient-header text-white p-6 rounded-b-3xl shadow-lg">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <h1 class="text-3xl font-bold">Bienvenue, {{ app.user.userIdentifier }}</h1>
        <a href="{{ path('app_logout') }}" class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/30 text-white px-4 py-2 rounded-lg transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
            Déconnexion
        </a>
    </div>
</div>

<div class="max-w-7xl mx-auto mt-8 grid gap-6">
    <!-- Navigation Card -->
    <div class="glass p-6 flex justify-around">
        <a href="{{ path('tenant_dashboard') }}" class="nav-link">Tableau de Bord</a>
        <a href="#" class="nav-link">Patrimoine</a>
        <a href="#" class="nav-link">Contrats</a>
        <a href="#" class="nav-link">Paiements</a>
        <a href="#" class="nav-link">Incidents</a>
    </div>

    <!-- Action Buttons -->
    <div class="flex gap-4 justify-end">
        <a href="#" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg">Générer Rapport</a>
        <a href="#" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg">Nouveau Contrat</a>
        <a href="#" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg">Patrimoine Global</a>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass p-4 text-center">
            <p class="text-gray-200 text-sm">0 Biens</p>
        </div>
        <div class="glass p-4 text-center">
            <p class="text-gray-200 text-sm">Taux d'Occupation</p>
            <p class="text-xl font-semibold">0 % (0 loués)</p>
        </div>
        <div class="glass p-4 text-center">
            <p class="text-gray-200 text-sm">Loyers Encaissés</p>
            <p class="text-xl font-semibold">0 GNF</p>
        </div>
        <div class="glass p-4 text-center">
            <p class="text-gray-200 text-sm">Impayés &amp; Retards</p>
            <p class="text-xl font-semibold">0 GNF</p>
        </div>
    </div>

    <!-- Revenue Evolution -->
    <div class="glass p-6">
        <h2 class="text-xl font-semibold mb-2">Évolution des Revenus</h2>
        <p class="text-gray-300 text-sm">Mise à jour en temps réel</p>
        <div class="h-48 bg-gray-800 flex items-center justify-center text-gray-500 mt-4 rounded">
            Graphique ici
        </div>
    </div>

    <!-- Latest Contracts -->
    <div class="glass p-6">
        <h2 class="text-xl font-semibold mb-2">Derniers Contrats Actifs</h2>
        <p class="text-gray-300">Aucun contrat enregistré pour le moment.</p>
        <a href="#" class="text-indigo-400 hover:underline mt-2 inline-block">Voir tout l'historique</a>
    </div>
</div>
{% endblock %}
