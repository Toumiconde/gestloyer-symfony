{% extends 'base.html.twig' %}

{% block title %}Connexion | GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-[80vh] flex items-center py-10">
    <div class="w-full grid grid-cols-1 lg:grid-cols-5 rounded-3xl overflow-hidden shadow-2xl border border-gray-100 dark:border-white/10">
        <section class="hidden lg:flex lg:col-span-3 flex-col justify-between bg-gradient-to-br from-slate-900 via-slate-800 to-green-700 text-white p-10">
            <div>
                <h2 class="text-4xl font-extrabold tracking-tight">
                    GEST<span class="text-green-400">LOYER</span>
                </h2>
                <p class="mt-3 text-sm text-slate-200">
                    Portail de gestion locative professionnelle
                </p>
            </div>

            <div class="space-y-4">
                <div class="rounded-xl bg-white/10 border border-white/15 p-4">
                    <p class="text-sm font-semibold">Pilotage centralise</p>
                    <p class="text-xs text-slate-200 mt-1">Suivi des biens, contrats, paiements et incidents sur une seule plateforme.</p>
                </div>
                <div class="rounded-xl bg-white/10 border border-white/15 p-4">
                    <p class="text-sm font-semibold">Donnees securisees</p>
                    <p class="text-xs text-slate-200 mt-1">Acces protege par roles utilisateurs et gestion des droits.</p>
                </div>
                <div class="rounded-xl bg-white/10 border border-white/15 p-4">
                    <p class="text-sm font-semibold">Suivi en temps reel</p>
                    <p class="text-xs text-slate-200 mt-1">Tableaux de bord et indicateurs pour un pilotage efficace de votre activite.</p>
                </div>
            </div>

            <p class="text-xs text-slate-300">
                Besoin d'aide ? Contact: support@gestloyer.com
            </p>
        </section>

        <section class="lg:col-span-2 bg-white/95 dark:bg-slate-800/95 backdrop-blur-md p-6 sm:p-10">
            <div class="max-w-md mx-auto text-center lg:text-left">
                <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white">
                    Connexion
                </h1>
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
                    Connecte-toi a ton espace GESTLOYER.
                </p>
            </div>

            <div class="mt-8 max-w-md mx-auto">
                {% if error %}
                    <div class="rounded-md bg-red-50 p-4 mb-6 border border-red-200">
                        <div class="flex">
                            <div class="ml-3">
                                <h3 class="text-sm font-medium text-red-800">{{ error.messageKey|trans(error.messageData, 'security') }}</h3>
                            </div>
                        </div>
                    </div>
                {% endif %}

                <form class="space-y-6" method="post" action="{{ path('app_login') }}">
                    <div>
                        <label for="inputEmail" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Adresse Email</label>
                        <div class="mt-1">
                            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" autocomplete="email" required autofocus class="appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-white/20 dark:bg-slate-700 dark:text-white rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm transition-colors">
                        </div>
                    </div>

                    <div>
                        <label for="inputPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Mot de passe</label>
                        <div class="mt-1">
                            <input type="password" name="_password" id="inputPassword" autocomplete="current-password" required class="appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-white/20 dark:bg-slate-700 dark:text-white rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm transition-colors">
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <input id="remember_me" name="_remember_me" type="checkbox" class="h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 dark:border-white/20 dark:bg-slate-700 rounded">
                            <label for="remember_me" class="ml-2 block text-sm text-gray-900 dark:text-gray-300"> Se souvenir de moi </label>
                        </div>

                        <div class="text-sm">
                            <a href="#" class="font-medium text-green-600 hover:text-green-500">Mot de passe oublié ?</a>
                        </div>
                    </div>

                    <div>
                        <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all shadow-green-500/30 hover:shadow-green-500/50">
                            Connexion
                        </button>
                    </div>

                    <p class="text-sm text-gray-600 dark:text-gray-400 text-center">
                        Pas de compte ?
                        <a href="{{ path('app_register') }}" class="font-semibold text-green-700 hover:text-green-600 dark:text-green-400 dark:hover:text-green-300">
                            Créer un compte
                        </a>
                    </p>
                </form>
            </div>
        </div>
        </section>
    </div>    
</div>
{% endblock %}
