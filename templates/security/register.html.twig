{% extends 'base.html.twig' %}

{% block title %}Inscription | GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-[80vh] flex items-center py-10">
    <div class="w-full grid grid-cols-1 lg:grid-cols-5 rounded-3xl overflow-hidden shadow-2xl border border-gray-100 dark:border-slate-200 dark:border-white/10">

        {# ── Panneau gauche décoratif ─────────────────────────────── #}
        <section class="hidden lg:flex lg:col-span-2 flex-col justify-between text-slate-900 dark:text-white p-10"
                 style="background: linear-gradient(145deg, #0f172a 0%, #1e1b4b 50%, #4c1d95 100%);">
            <div>
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center"
                         style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                        <svg class="w-5 h-5 text-slate-900 dark:text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" />
                        </svg>
                    </div>
                    <span class="text-2xl font-bold tracking-tight">GEST<span class="text-violet-400">LOYER</span></span>
                </div>

                <h2 class="text-3xl font-extrabold leading-tight mb-4">
                    Rejoignez notre<br>
                    <span class="text-violet-400">plateforme locative</span>
                </h2>
                <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed mb-8">
                    Gérez vos biens, suivez vos paiements et restez informé en temps réel.
                </p>

                <div class="space-y-3">
                    <div class="flex items-start gap-3 rounded-2xl p-4 border border-slate-200 dark:border-white/10 bg-white dark:bg-slate-800">
                        <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center bg-violet-500/20 text-violet-300">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">Locataire</p>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-0.5">Consultez vos paiements, incidents et documents en un clin d'œil.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 rounded-2xl p-4 border border-slate-200 dark:border-white/10 bg-white dark:bg-slate-800">
                        <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center bg-emerald-500/20 text-emerald-300">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-slate-900 dark:text-white">Propriétaire</p>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-0.5">Suivez vos biens, contrats et reversements en toute transparence.</p>
                        </div>
                    </div>
                </div>
            </div>

            <p class="text-xs text-slate-500 mt-8">Support : support@gestloyer.com</p>
        </section>

        {# ── Formulaire ────────────────────────────────────────────── #}
        <section class="lg:col-span-3 bg-white dark:bg-slate-900 p-6 sm:p-10 overflow-y-auto relative">
            <a href="{{ path('app_home') }}" class="absolute top-4 sm:top-6 left-4 sm:left-6 text-sm font-medium text-slate-500 hover:text-emerald-600 dark:hover:text-emerald-400 transition flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Retour
            </a>
            <div class="max-w-lg mx-auto mt-6 sm:mt-8">
                <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-gray-900 dark:text-slate-900 dark:text-white">
                    Créer un compte
                </h1>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                    Remplissez toutes les informations pour finaliser votre inscription.
                </p>

                {# Flash messages #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mt-4 rounded-xl p-3 flex items-center gap-3 text-sm
                            {% if label == 'error' %}bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/30 text-rose-700 dark:text-rose-300
                            {% else %}bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30 text-emerald-700 dark:text-emerald-300{% endif %}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <form id="register-form" class="mt-6 space-y-5" method="post" action="{{ path('app_register') }}">

                    {# ── Type de compte ──────────────────────────────── #}
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 dark:text-slate-700 dark:text-slate-700 dark:text-slate-300 mb-2">
                            Type de compte
                        </label>
                        <div class="grid grid-cols-2 gap-3" id="type-btns">
                            <button type="button" id="btn-locataire"
                                    onclick="selectType('locataire')"
                                    class="type-btn relative flex items-center gap-3 rounded-2xl px-4 py-4 border-2 border-gray-200 dark:border-slate-200 dark:border-white/10 transition-all duration-200 cursor-pointer text-left hover:border-emerald-400 dark:hover:border-emerald-500 group">
                                <div class="w-9 h-9 rounded-xl flex-shrink-0 flex items-center justify-center transition-colors
                                            bg-gray-100 dark:bg-slate-100 dark:bg-white/5 group-[.selected]:bg-emerald-500">
                                    <svg class="w-4 h-4 text-slate-600 dark:text-slate-400 group-[.selected]:text-slate-900 dark:group-[.selected]:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-gray-900 dark:text-slate-900 dark:text-white">Locataire</p>
                                    <p class="text-xs text-slate-600 dark:text-slate-400">Accès paiements & docs</p>
                                </div>
                                <div class="absolute top-2 right-2 w-5 h-5 rounded-full border-2 border-gray-300 dark:border-slate-300 dark:border-white/20
                                            flex items-center justify-center transition-all
                                            group-[.selected]:bg-emerald-500 group-[.selected]:border-emerald-500">
                                    <svg class="w-3 h-3 text-slate-900 dark:text-white hidden group-[.selected]:block" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                </div>
                            </button>

                            <button type="button" id="btn-proprietaire"
                                    onclick="selectType('proprietaire')"
                                    class="type-btn relative flex items-center gap-3 rounded-2xl px-4 py-4 border-2 border-gray-200 dark:border-slate-200 dark:border-white/10 transition-all duration-200 cursor-pointer text-left hover:border-emerald-400 dark:hover:border-emerald-500 group">
                                <div class="w-9 h-9 rounded-xl flex-shrink-0 flex items-center justify-center transition-colors
                                            bg-gray-100 dark:bg-slate-100 dark:bg-white/5 group-[.selected]:bg-emerald-500">
                                    <svg class="w-4 h-4 text-slate-500 dark:text-slate-400 dark:text-slate-600 dark:text-slate-400 group-[.selected]:text-slate-900 dark:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-gray-900 dark:text-slate-900 dark:text-white">Propriétaire</p>
                                    <p class="text-xs text-slate-600 dark:text-slate-400">Biens, contrats & reversements</p>
                                </div>
                                <div class="absolute top-2 right-2 w-5 h-5 rounded-full border-2 border-gray-300 dark:border-slate-300 dark:border-white/20
                                            flex items-center justify-center transition-all
                                            group-[.selected]:bg-emerald-500 group-[.selected]:border-emerald-500">
                                    <svg class="w-3 h-3 text-slate-900 dark:text-white hidden group-[.selected]:block" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                </div>
                            </button>
                        </div>
                        {# Hidden input soumis avec le formulaire #}
                        <input type="hidden" name="type" id="type-input" value="" required>
                        <p id="type-error" class="hidden mt-1.5 text-xs text-rose-500">Veuillez sélectionner un type de compte.</p>
                    </div>

                    {# ── Nom & Prénom ───────────────────────────────── #}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label for="regNom" class="block text-sm font-semibold text-gray-700 dark:text-slate-700 dark:text-slate-700 dark:text-slate-300 mb-1.5">
                                Nom
                            </label>
                            <input id="regNom" name="nom" type="text" autocomplete="family-name" required
                                   placeholder="Diallo"
                                   class="block w-full rounded-xl px-4 py-2.5 text-sm border border-gray-300 dark:border-white/15 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition">
                        </div>
                        <div>
                            <label for="regPrenom" class="block text-sm font-semibold text-gray-700 dark:text-slate-700 dark:text-slate-700 dark:text-slate-300 mb-1.5">
                                Prénom
                            </label>
                            <input id="regPrenom" name="prenom" type="text" autocomplete="given-name" required
                                   placeholder="Mamadou"
                                   class="block w-full rounded-xl px-4 py-2.5 text-sm border border-gray-300 dark:border-white/15 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition">
                        </div>
                    </div>

                    {# ── Téléphone ─────────────────────────────────── #}
                    <div>
                        <label for="regTel" class="block text-sm font-semibold text-gray-700 dark:text-slate-700 dark:text-slate-700 dark:text-slate-300 mb-1.5">
                            Numéro de téléphone
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500 dark:text-slate-600 dark:text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                                </svg>
                            </div>
                            <input id="regTel" name="telephone" type="tel" autocomplete="tel" required
                                   placeholder="+224 6XX XXX XXX"
                                   class="block w-full pl-10 rounded-xl px-4 py-2.5 text-sm border border-gray-300 dark:border-white/15 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition">
                        </div>
                    </div>

                    {# ── Email ─────────────────────────────────────── #}
                    <div>
                        <label for="regEmail" class="block text-sm font-semibold text-gray-700 dark:text-slate-700 dark:text-slate-700 dark:text-slate-300 mb-1.5">
                            Adresse e-mail
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500 dark:text-slate-600 dark:text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15A2.25 2.25 0 012.25 17.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15A2.25 2.25 0 002.25 6.75m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.909A2.25 2.25 0 012.25 6.993V6.75" />
                                </svg>
                            </div>
                            <input id="regEmail" name="email" type="email" autocomplete="email" required
                                   placeholder="mamadou@exemple.com"
                                   class="block w-full pl-10 rounded-xl px-4 py-2.5 text-sm border border-gray-300 dark:border-white/15 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition">
                        </div>
                    </div>

                    {# ── Mot de passe ──────────────────────────────── #}
                    <div>
                        <label for="regPassword" class="block text-sm font-semibold text-gray-700 dark:text-slate-700 dark:text-slate-700 dark:text-slate-300 mb-1.5">
                            Mot de passe
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-slate-500 dark:text-slate-600 dark:text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                                </svg>
                            </div>
                            <input id="regPassword" name="password" type="password" autocomplete="new-password" required
                                   placeholder="••••••••"
                                   class="block w-full pl-10 rounded-xl px-4 py-2.5 text-sm border border-gray-300 dark:border-white/15 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition">
                        </div>
                        <div class="mt-2 flex gap-1.5" id="strength-bars">
                            <div class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-white/10" id="sb1"></div>
                            <div class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-white/10" id="sb2"></div>
                            <div class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-white/10" id="sb3"></div>
                            <div class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-white/10" id="sb4"></div>
                        </div>
                        <p class="mt-1 text-xs text-slate-600 dark:text-slate-400">Minimum 6 caractères.</p>
                    </div>

                    {# ── Bouton submit ─────────────────────────────── #}
                    <button type="submit" id="submit-btn"
                            class="w-full flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold text-slate-900 dark:text-white transition-all shadow-lg hover:-translate-y-0.5 hover:shadow-emerald-500/30"
                            style="background: linear-gradient(135deg, #10b981, #059669);">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
                        </svg>
                        Créer mon compte
                    </button>

                    <p class="text-sm text-gray-700 dark:text-slate-400 text-center">
                        Déjà un compte ?
                        <a href="{{ path('app_login') }}" class="font-semibold text-emerald-600 hover:text-emerald-500 transition-colors">Se connecter</a>
                    </p>
                </form>
            </div>
        </section>

    </div>
</div>

<script>
    // ── Sélection du type de compte ──────────────────────────────────
    function selectType(value) {
        const input = document.getElementById('type-input');
        const errMsg = document.getElementById('type-error');
        const btns = document.querySelectorAll('.type-btn');

        input.value = value;
        errMsg.classList.add('hidden');

        btns.forEach(btn => {
            btn.classList.remove('selected', 'border-emerald-500', 'dark:border-emerald-500',
                'bg-emerald-50', 'dark:bg-emerald-500/10');
        });

        const target = document.getElementById('btn-' + value);
        if (target) {
            target.classList.add('selected', 'border-emerald-500', 'dark:border-emerald-500',
                'bg-emerald-50', 'dark:bg-emerald-500/10');
        }
    }

    // ── Validation avant soumission ──────────────────────────────────
    document.getElementById('register-form').addEventListener('submit', function (e) {
        const type = document.getElementById('type-input').value;
        if (!type) {
            e.preventDefault();
            document.getElementById('type-error').classList.remove('hidden');
            document.getElementById('type-btns').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });

    // ── Indicateur de force du mot de passe ─────────────────────────
    document.getElementById('regPassword').addEventListener('input', function () {
        const val = this.value;
        const bars = [
            document.getElementById('sb1'),
            document.getElementById('sb2'),
            document.getElementById('sb3'),
            document.getElementById('sb4'),
        ];

        let strength = 0;
        if (val.length >= 6) strength++;
        if (val.length >= 10) strength++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        const colors = ['bg-rose-500', 'bg-amber-500', 'bg-yellow-400', 'bg-emerald-500'];

        bars.forEach((bar, i) => {
            bar.className = 'h-1 flex-1 rounded-full transition-all duration-300 ';
            if (i < strength) {
                bar.classList.add(colors[strength - 1] || 'bg-gray-200');
            } else {
                bar.classList.add('bg-gray-200', 'dark:bg-white/10');
            }
        });
    });
</script>
{% endblock %}
