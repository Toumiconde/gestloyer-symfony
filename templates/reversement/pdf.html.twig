{# templates/reversement/pdf.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: "DejaVu Sans", sans-serif;
            font-size: 12px;
            color: #1e293b;
            background: #fff;
            padding: 30px;
        }

        /* ── En-tête ── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 3px solid #4f46e5;
            padding-bottom: 16px;
            margin-bottom: 24px;
        }
        .header-left h1 {
            font-size: 22px;
            font-weight: bold;
            color: #4f46e5;
        }
        .header-left p {
            font-size: 11px;
            color: #64748b;
            margin-top: 4px;
        }
        .header-right {
            text-align: right;
            font-size: 11px;
            color: #64748b;
        }
        .badge {
            display: inline-block;
            margin-top: 6px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: bold;
        }
        .badge-verse   { background: #d1fae5; color: #065f46; }
        .badge-attente { background: #fef3c7; color: #92400e; }
        .badge-calcule { background: #e2e8f0; color: #334155; }
        .badge-annule  { background: #fee2e2; color: #991b1b; }

        /* ── Infos propriétaire ── */
        .section-title {
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            color: #64748b;
            letter-spacing: 0.05em;
            margin-bottom: 8px;
        }
        .info-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 14px 18px;
            margin-bottom: 20px;
        }
        .info-box p {
            margin-bottom: 4px;
        }
        .info-box strong { color: #0f172a; }

        /* ── Tableau des montants ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        thead tr {
            background: #4f46e5;
            color: #fff;
        }
        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        tbody tr:nth-child(even) { background: #f1f5f9; }
        tbody tr:nth-child(odd)  { background: #ffffff; }
        tbody td {
            padding: 10px 14px;
            border-bottom: 1px solid #e2e8f0;
        }
        .amount { text-align: right; font-weight: bold; }
        .minus   { color: #dc2626; }
        .total   { color: #059669; font-size: 14px; }

        /* ── Total net ── */
        .total-box {
            background: #ecfdf5;
            border: 2px solid #10b981;
            border-radius: 8px;
            padding: 16px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        .total-box .label { font-size: 13px; font-weight: bold; color: #065f46; }
        .total-box .value { font-size: 18px; font-weight: bold; color: #065f46; }

        /* ── Pied de page ── */
        .footer {
            border-top: 1px solid #e2e8f0;
            padding-top: 12px;
            font-size: 10px;
            color: #94a3b8;
            text-align: center;
        }
    </style>
</head>
<body>

    {# ── En-tête ── #}
    <div class="header">
        <div class="header-left">
            <h1>GESTLOYER</h1>
            <p>Gestion Locative Professionnelle</p>
        </div>
        <div class="header-right">
            <strong>Bordereau de Reversement</strong><br>
            N° BRV-{{ "%05d"|format(reversement.id) }}<br>
            Généré le : {{ "now"|date("d/m/Y") }}<br>
            {% set statut_val = reversement.statut.value %}
            {% if statut_val == 'VERSE' %}
                <span class="badge badge-verse">{{ statut_val }}</span>
            {% elseif statut_val == 'EN_ATTENTE' %}
                <span class="badge badge-attente">{{ statut_val }}</span>
            {% elseif statut_val == 'ANNULE' %}
                <span class="badge badge-annule">{{ statut_val }}</span>
            {% else %}
                <span class="badge badge-calcule">{{ statut_val }}</span>
            {% endif %}
        </div>
    </div>

    {# ── Infos propriétaire ── #}
    {% if reversement.proprietaire %}
    <p class="section-title">Propriétaire</p>
    <div class="info-box">
        <p><strong>Nom :</strong> {{ reversement.proprietaire.nom }} {{ reversement.proprietaire.prenom }}</p>
        {% if reversement.proprietaire.telephone %}
        <p><strong>Téléphone :</strong> {{ reversement.proprietaire.telephone }}</p>
        {% endif %}
        {% if reversement.proprietaire.user %}
        <p><strong>Email :</strong> {{ reversement.proprietaire.user.email }}</p>
        {% endif %}
        <p><strong>Période :</strong> {{ reversement.mois ? reversement.mois|date('F Y')|capitalize : 'N/A' }}</p>
    </div>
    {% endif %}

    {# ── Détail des montants ── #}
    <p class="section-title">Détail du reversement</p>
    <table>
        <thead>
            <tr>
                <th>Libellé</th>
                <th style="text-align:right">Montant (GNF)</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Montant brut collecté</td>
                <td class="amount">{{ reversement.montantBrut|number_format(0, ',', ' ') }}</td>
            </tr>
            <tr>
                <td>Commission agence (déduite)</td>
                <td class="amount minus">- {{ reversement.commission|number_format(0, ',', ' ') }}</td>
            </tr>
            <tr>
                <td>Frais de maintenance (déduits)</td>
                <td class="amount minus">- {{ reversement.fraisMaintenance|number_format(0, ',', ' ') }}</td>
            </tr>
        </tbody>
    </table>

    {# ── Total net ── #}
    <div class="total-box">
        <span class="label">💰 Net versé au propriétaire</span>
        <span class="value">{{ reversement.montantNet|number_format(0, ',', ' ') }} GNF</span>
    </div>

    {# ── Pied de page ── #}
    <div class="footer">
        Ce document est généré automatiquement par la plateforme GESTLOYER. Il tient lieu de justificatif de versement.
        <br>
        Bordereau N° BRV-{{ "%05d"|format(reversement.id) }} — Période : {{ reversement.mois ? reversement.mois|date('F Y')|capitalize : 'N/A' }}
    </div>

</body>
</html>
