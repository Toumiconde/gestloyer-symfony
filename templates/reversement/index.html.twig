{% extends 'base.html.twig' %}

{% block title %}Mes Reversements — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen pb-12 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 py-8">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white">💳 Historique des Reversements</h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">{{ reversements|length }} reversement{{ reversements|length > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('app_dashboard_proprietaire') }}"
               class="px-4 py-2 rounded-xl text-sm font-medium text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition">
                ← Retour dashboard
            </a>
        </div>

        {# Résumé total #}
        {% if reversements|length > 0 %}
        <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="rounded-2xl p-5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm text-center">
                <p class="text-xs font-semibold text-slate-400 uppercase mb-2">Total Brut</p>
                <p class="text-2xl font-bold text-slate-900 dark:text-white">
                    {{ reversements|reduce((carry, r) => carry + r.montantBrut, 0)|number_format(0, ',', ' ') }} GNF
                </p>
            </div>
            <div class="rounded-2xl p-5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm text-center">
                <p class="text-xs font-semibold text-slate-400 uppercase mb-2">Total Commission</p>
                <p class="text-2xl font-bold text-rose-600 dark:text-rose-400">
                    {{ reversements|reduce((carry, r) => carry + r.commission, 0)|number_format(0, ',', ' ') }} GNF
                </p>
            </div>
            <div class="rounded-2xl p-5 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 shadow-sm text-center">
                <p class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 uppercase mb-2">Total Net Reçu</p>
                <p class="text-2xl font-bold text-emerald-700 dark:text-emerald-400">
                    {{ reversements|reduce((carry, r) => carry + r.montantNet, 0)|number_format(0, ',', ' ') }} GNF
                </p>
            </div>
        </div>
        {% endif %}

        {# Table #}
        <div class="rounded-2xl overflow-hidden bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/80 border-b border-slate-200 dark:border-slate-700">
                        <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Mois</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Brut</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Commission</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Frais</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Net Versé</th>
                        <th class="text-center px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Statut</th>
                        <th class="text-center px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Bordereau</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50">
                    {% for rev in reversements %}
                    {% set sc_map = {'CALCULE': 'slate', 'EN_ATTENTE': 'amber', 'VERSE': 'emerald', 'ANNULE': 'red'} %}
                    {% set sc = sc_map[rev.statut.value] ?? 'slate' %}
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/20 transition">
                        <td class="px-6 py-4 text-sm font-medium text-slate-900 dark:text-white">
                            {{ rev.mois ? rev.mois|date('F Y')|capitalize : 'N/A' }}
                        </td>
                        <td class="px-6 py-4 text-right text-sm text-slate-700 dark:text-slate-300">
                            {{ rev.montantBrut|number_format(0, ',', ' ') }} GNF
                        </td>
                        <td class="px-6 py-4 text-right text-sm text-rose-600 dark:text-rose-400">
                            - {{ rev.commission|number_format(0, ',', ' ') }} GNF
                        </td>
                        <td class="px-6 py-4 text-right text-sm text-orange-600 dark:text-orange-400">
                            - {{ rev.fraisMaintenance|number_format(0, ',', ' ') }} GNF
                        </td>
                        <td class="px-6 py-4 text-right text-sm font-bold text-emerald-600 dark:text-emerald-400">
                            {{ rev.montantNet|number_format(0, ',', ' ') }} GNF
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-xs px-3 py-1 rounded-full font-medium bg-{{ sc }}-100 dark:bg-{{ sc }}-500/20 text-{{ sc }}-700 dark:text-{{ sc }}-400">
                                {{ rev.statut.value }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <a href="{{ path('app_reversement_pdf', {id: rev.id}) }}"
                               class="text-xs px-3 py-1.5 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-100 transition inline-flex items-center gap-1">
                                📄 Télécharger
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="px-6 py-16 text-center">
                            <div class="text-4xl mb-3">💳</div>
                            <p class="text-slate-500 dark:text-slate-400">Aucun reversement enregistré.</p>
                            <p class="text-xs text-slate-400 mt-1">Les reversements apparaissent ici après validation par le comptable.</p>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}