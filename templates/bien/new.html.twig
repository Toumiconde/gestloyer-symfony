{% extends 'base.html.twig' %}

{% block title %}Ajouter un Bien | GESTLOYER{% endblock %}

{% block body %}
    <div class="mb-8">
        <a href="{{ path('app_bien_index') }}" class="text-sm font-medium text-gray-500 hover:text-gray-700 flex items-center mb-4">
            <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
            </svg>
            Retour au patrimoine
        </a>
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Ajouter un Bien Immobilier</h1>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Complétez le formulaire ci-dessous pour enregistrer une nouvelle propriété.</p>
    </div>

    <div class="card p-6 md:p-8 max-w-3xl">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            
            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
                <div class="sm:col-span-2">
                    {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    <div class="mt-1">
                        {{ form_widget(form.nom) }}
                    </div>
                    {{ form_errors(form.nom, {'attr': {'class': 'text-sm text-red-600 mt-1'}}) }}
                </div>

                <div class="sm:col-span-2">
                    {{ form_label(form.adresse, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    <div class="mt-1">
                        {{ form_widget(form.adresse) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.type, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    <div class="mt-1">
                        {{ form_widget(form.type) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.statut, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    <div class="mt-1">
                        {{ form_widget(form.statut) }}
                    </div>
                </div>

                <div class="sm:col-span-2">
                    {{ form_label(form.proprietaire, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    <div class="mt-1">
                        {{ form_widget(form.proprietaire) }}
                    </div>
                </div>
            </div>

            <div class="pt-5 flex justify-end gap-3 border-t border-gray-200 mt-8">
                <a href="{{ path('app_bien_index') }}" class="btn-secondary">Annuler</a>
                <button type="submit" class="btn-primary">
                    <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    Enregistrer le bien
                </button>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
