{% extends 'base.html.twig' %}

{% block title %}Ajouter un Bien | GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen pb-16 bg-gray-50 dark:bg-slate-900">
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# ── HEADER ──────────────────────────────────────────────────────── #}
    <div class="mb-8">
        <a href="{{ path('app_bien_index') }}"
           class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            Retour au patrimoine
        </a>
        <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Ajouter un Bien</h1>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Remplissez les informations puis ajoutez les photos de la propriété.</p>
    </div>

    {{ form_start(form, {
        'attr': {
            'id': 'bien-form',
            'enctype': 'multipart/form-data',
            'class': 'space-y-6'
        }
    }) }}

    {# ── SECTION 1 : INFORMATIONS GÉNÉRALES ─────────────────────────── #}
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700/60 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50 flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-100 dark:bg-indigo-500/20 flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
            </div>
            <h2 class="text-base font-bold text-slate-900 dark:text-white">Informations générales</h2>
        </div>
        <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-5">

            <div class="sm:col-span-2">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.nom, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition text-sm', 'placeholder': 'Ex : Villa les Manguiers'}}) }}
                {{ form_errors(form.nom) }}
            </div>

            <div class="sm:col-span-2">
                {{ form_label(form.adresse, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.adresse, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition text-sm', 'rows': 2, 'placeholder': 'Adresse complète du bien'}}) }}
            </div>

            <div>
                {{ form_label(form.emplacement, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.emplacement, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition text-sm', 'placeholder': 'Ex : Kaloum, Ratoma…'}}) }}
            </div>

            <div>
                {{ form_label(form.proprietaire, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.proprietaire, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition text-sm'}}) }}
            </div>

            <div>
                {{ form_label(form.type, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.type, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition text-sm'}}) }}
            </div>

            <div>
                {{ form_label(form.statut, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.statut, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition text-sm'}}) }}
            </div>

        </div>
    </div>

    {# ── SECTION 2 : CARACTÉRISTIQUES ───────────────────────────────── #}
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700/60 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50 flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <h2 class="text-base font-bold text-slate-900 dark:text-white">Caractéristiques</h2>
        </div>
        <div class="p-6 grid grid-cols-1 sm:grid-cols-3 gap-5">

            <div>
                {{ form_label(form.nbChambres, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5'}}) }}
                {{ form_widget(form.nbChambres, {'attr': {'class': 'w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition text-sm', 'placeholder': '0'}}) }}
            </div>

            <div class="flex items-center gap-3 pt-6">
                {{ form_widget(form.doucheInterne, {'attr': {'class': 'w-4 h-4 text-indigo-600 rounded border-slate-300 dark:border-slate-600 focus:ring-indigo-500'}}) }}
                {{ form_label(form.doucheInterne, null, {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300 cursor-pointer'}}) }}
            </div>

            <div class="flex items-center gap-3 pt-6">
                {{ form_widget(form.doucheExterne, {'attr': {'class': 'w-4 h-4 text-indigo-600 rounded border-slate-300 dark:border-slate-600 focus:ring-indigo-500'}}) }}
                {{ form_label(form.doucheExterne, null, {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300 cursor-pointer'}}) }}
            </div>

            <div class="flex items-center gap-3">
                {{ form_widget(form.hasTerrasse, {'attr': {'class': 'w-4 h-4 text-indigo-600 rounded border-slate-300 dark:border-slate-600 focus:ring-indigo-500'}}) }}
                {{ form_label(form.hasTerrasse, null, {'label_attr': {'class': 'text-sm font-semibold text-slate-700 dark:text-slate-300 cursor-pointer'}}) }}
            </div>

        </div>
    </div>

    {# ── SECTION 3 : PHOTOS ──────────────────────────────────────────── #}
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700/60 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700/50 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-500/20 flex items-center justify-center">
                    <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-base font-bold text-slate-900 dark:text-white">Photos du bien</h2>
                    <p class="text-xs text-slate-400 mt-0.5">Façade, chambres, douche, salon… autant que vous voulez</p>
                </div>
            </div>
            <span id="photo-count-badge" class="hidden text-xs font-bold px-2.5 py-1 rounded-full bg-indigo-100 dark:bg-indigo-500/20 text-indigo-600 dark:text-indigo-400">
                0 photo(s)
            </span>
        </div>

        <div class="p-6 space-y-4">

            {# Zone de dépôt principale #}
            <div id="drop-zone"
                 class="relative border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-2xl p-8 text-center cursor-pointer hover:border-indigo-400 dark:hover:border-indigo-500 hover:bg-indigo-50/30 dark:hover:bg-indigo-500/5 transition-all duration-200"
                 onclick="document.getElementById('file-input-gallery').click()">
                <div class="flex flex-col items-center gap-3">
                    <div class="w-14 h-14 rounded-2xl bg-slate-100 dark:bg-slate-700 flex items-center justify-center">
                        <svg class="w-7 h-7 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">Glissez vos photos ici</p>
                        <p class="text-xs text-slate-400 mt-0.5">ou cliquez pour choisir depuis votre machine</p>
                    </div>
                    <p class="text-xs text-slate-400">JPG, PNG, WEBP — plusieurs fichiers acceptés</p>
                </div>
                <input id="file-input-gallery" type="file" accept="image/*" multiple class="hidden">
            </div>

            {# Bouton Prendre une photo (caméra) #}
            <div class="flex items-center gap-3">
                <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
                <span class="text-xs text-slate-400 font-medium">ou</span>
                <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
            </div>

            <button type="button" id="btn-camera"
                    onclick="document.getElementById('file-input-camera').click()"
                    class="w-full flex items-center justify-center gap-2.5 px-4 py-3 rounded-xl border-2 border-dashed border-indigo-300 dark:border-indigo-500/40 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-500/10 transition font-semibold text-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Prendre une photo avec l'appareil photo
            </button>
            <input id="file-input-camera" type="file" accept="image/*" capture="environment" class="hidden">

            {# Grille de prévisualisations #}
            <div id="photo-preview-grid" class="hidden grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mt-4"></div>

            {# Conteneur des inputs cachés (générés par JS) #}
            <div id="photo-inputs-container"></div>

        </div>
    </div>

    {# ── BOUTONS ─────────────────────────────────────────────────────── #}
    <div class="flex items-center justify-end gap-3 pt-2">
        <a href="{{ path('app_bien_index') }}"
           class="px-5 py-2.5 rounded-xl text-sm font-semibold text-slate-700 dark:text-slate-200 bg-white dark:bg-slate-700 border border-slate-300 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-600 transition">
            Annuler
        </a>
        <button type="submit"
                class="inline-flex items-center gap-2 px-6 py-2.5 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-600/25 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
            Enregistrer le bien
        </button>
    </div>

    {{ form_end(form) }}

</div>
</div>

<script>
(function () {
    const categories = {{ categories|json_encode|raw }};
    const grid       = document.getElementById('photo-preview-grid');
    const container  = document.getElementById('photo-inputs-container');
    const badge      = document.getElementById('photo-count-badge');
    const dropZone   = document.getElementById('drop-zone');
    let   photoIndex = 0;

    function updateBadge() {
        const count = grid.querySelectorAll('.photo-card').length;
        badge.textContent = count + ' photo' + (count > 1 ? 's' : '');
        badge.classList.toggle('hidden', count === 0);
        grid.classList.toggle('hidden', count === 0);
    }

    function buildCategoryOptions(selected) {
        return Object.entries(categories)
            .map(([val, label]) =>
                `<option value="${val}" ${val === selected ? 'selected' : ''}>${label}</option>`)
            .join('');
    }

    function addPhoto(file) {
        const idx    = photoIndex++;
        const reader = new FileReader();

        reader.onload = function (e) {
            const card = document.createElement('div');
            card.className = 'photo-card relative group rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 shadow-sm';
            card.innerHTML = `
                <img src="${e.target.result}"
                     class="w-full h-32 object-cover"
                     alt="Aperçu">
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-200"></div>
                <button type="button" data-idx="${idx}"
                        class="btn-remove-photo absolute top-1.5 right-1.5 w-7 h-7 rounded-full bg-red-500 text-white opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center shadow-lg hover:bg-red-600">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
                <div class="absolute bottom-0 left-0 right-0 p-1.5 bg-black/50">
                    <select name="photo_categories[${idx}]"
                            class="w-full text-xs rounded-lg border-0 bg-white/90 dark:bg-slate-800/90 text-slate-900 dark:text-white px-2 py-1 focus:ring-1 focus:ring-indigo-400">
                        ${buildCategoryOptions('autre')}
                    </select>
                </div>`;
            grid.appendChild(card);

            // Input file caché
            const dt    = new DataTransfer();
            dt.items.add(file);
            const input = document.createElement('input');
            input.type  = 'file';
            input.name  = `photos[${idx}]`;
            input.files = dt.files;
            input.className = 'hidden';
            input.dataset.idx = idx;
            container.appendChild(input);

            card.querySelector('.btn-remove-photo').addEventListener('click', function () {
                const i = this.dataset.idx;
                card.remove();
                container.querySelector(`[data-idx="${i}"]`).remove();
                updateBadge();
            });

            updateBadge();
        };

        reader.readAsDataURL(file);
    }

    function handleFiles(files) {
        Array.from(files).forEach(file => {
            if (!file.type.startsWith('image/')) return;
            addPhoto(file);
        });
    }

    // Galerie
    document.getElementById('file-input-gallery').addEventListener('change', function () {
        handleFiles(this.files);
        this.value = '';
    });

    // Caméra
    document.getElementById('file-input-camera').addEventListener('change', function () {
        handleFiles(this.files);
        this.value = '';
    });

    // Drag & drop
    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        this.classList.add('border-indigo-400', 'bg-indigo-50/40', 'dark:bg-indigo-500/10');
    });
    dropZone.addEventListener('dragleave', function () {
        this.classList.remove('border-indigo-400', 'bg-indigo-50/40', 'dark:bg-indigo-500/10');
    });
    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        this.classList.remove('border-indigo-400', 'bg-indigo-50/40', 'dark:bg-indigo-500/10');
        handleFiles(e.dataTransfer.files);
    });
})();
</script>
{% endblock %}
