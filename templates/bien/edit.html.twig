{% extends 'base.html.twig' %}

{% block title %}Modifier {{ bien.nom }} | GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen pb-12 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# ── HEADER ─────────────────────────────────────────────────────────── #}
        <div class="mb-8">
            <a href="{{ path('app_bien_show', {id: bien.id}) }}"
               class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
                </svg>
                Retour au bien
            </a>
            <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">✏️ Modifier le Bien</h1>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{{ bien.nom }} — Modifiez les informations ci-dessous.</p>
        </div>

        {# ── FORMULAIRE ──────────────────────────────────────────────────────── #}
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm p-6 md:p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

                <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
                    <div class="sm:col-span-2">
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                        {{ form_widget(form.nom) }}
                        {{ form_errors(form.nom, {'attr': {'class': 'text-sm text-red-500 mt-1'}}) }}
                    </div>

                    <div class="sm:col-span-2">
                        {{ form_label(form.adresse, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                        {{ form_widget(form.adresse) }}
                        {{ form_errors(form.adresse) }}
                    </div>

                    <div>
                        {{ form_label(form.type, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                        {{ form_widget(form.type) }}
                        {{ form_errors(form.type) }}
                    </div>

                    <div>
                        {{ form_label(form.statut, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                        {{ form_widget(form.statut) }}
                        {{ form_errors(form.statut) }}
                    </div>

                    <div class="sm:col-span-2">
                        {{ form_label(form.proprietaire, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                        {{ form_widget(form.proprietaire) }}
                        {{ form_errors(form.proprietaire) }}
                    </div>
                </div>

                {# ── Séparateur Caractéristiques ────────────────────────────── #}
                <div class="pt-6 border-t border-slate-200 dark:border-slate-700">
                    <h3 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-4">Caractéristiques</h3>
                    <div class="grid grid-cols-1 gap-y-4 gap-x-4 sm:grid-cols-2">

                        {% if form.emplacement is defined %}
                        <div class="sm:col-span-2">
                            {{ form_label(form.emplacement, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                            {{ form_widget(form.emplacement) }}
                        </div>
                        {% endif %}

                        {% if form.nbChambres is defined %}
                        <div>
                            {{ form_label(form.nbChambres, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-slate-300 mb-1'}}) }}
                            {{ form_widget(form.nbChambres) }}
                        </div>
                        {% endif %}

                        {% if form.doucheInterne is defined %}
                        <div class="flex items-center gap-3 pt-2">
                            {{ form_widget(form.doucheInterne) }}
                            {{ form_label(form.doucheInterne, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 dark:text-slate-300'}}) }}
                        </div>
                        {% endif %}

                        {% if form.doucheExterne is defined %}
                        <div class="flex items-center gap-3 pt-2">
                            {{ form_widget(form.doucheExterne) }}
                            {{ form_label(form.doucheExterne, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 dark:text-slate-300'}}) }}
                        </div>
                        {% endif %}

                        {% if form.hasTerrasse is defined %}
                        <div class="flex items-center gap-3 pt-2">
                            {{ form_widget(form.hasTerrasse) }}
                            {{ form_label(form.hasTerrasse, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 dark:text-slate-300'}}) }}
                        </div>
                        {% endif %}

                    </div>
                </div>

                {# ── Boutons ─────────────────────────────────────────────────── #}
                <div class="pt-6 flex justify-end gap-3 border-t border-slate-200 dark:border-slate-700">
                    <a href="{{ path('app_bien_show', {id: bien.id}) }}"
                       class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-slate-700 dark:text-slate-200 bg-white dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-600 transition">
                        Annuler
                    </a>
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-600/20 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.5 12.75l6 6 9-13.5"/>
                        </svg>
                        Enregistrer les modifications
                    </button>
                </div>

            {{ form_end(form) }}
        </div>

    </div>
</div>
{% endblock %}
