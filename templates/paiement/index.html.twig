{% extends 'base.html.twig' %}

{% block title %}Paiements — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen pb-12 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 py-8">

        <div class="flex items-center justify-between mb-6">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <a href="{{ app.user.role.value == 'LOCATAIRE' ? path('app_dashboard_locataire') : (app.user.role.value == 'PROPRIETAIRE' ? path('app_dashboard_proprietaire') : path('app_dashboard')) }}" class="p-2 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 transition shadow-sm text-slate-500 dark:text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    </a>
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">💰 Paiements</h1>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">{{ paiements|length }} paiement{{ paiements|length > 1 ? 's' : '' }}</p>
            </div>
        </div>

        {# Totaux #}
        <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="rounded-xl p-4 text-center bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 shadow-sm">
                <div class="text-sm font-semibold text-emerald-800 dark:text-emerald-300 mb-1">Total Versé</div>
                <div class="text-xl font-bold text-emerald-600 dark:text-emerald-400">{{ total_verse|number_format(0, ',', ' ') }} GNF</div>
            </div>
            <div class="rounded-xl p-4 text-center bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 shadow-sm">
                <div class="text-sm font-semibold text-rose-800 dark:text-rose-300 mb-1">Solde Restant (Impayé)</div>
                <div class="text-xl font-bold text-rose-600 dark:text-rose-400">{{ solde_total|number_format(0, ',', ' ') }} GNF</div>
            </div>
            <div class="rounded-xl p-4 text-center bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/20 shadow-sm">
                <div class="text-sm font-semibold text-indigo-800 dark:text-indigo-300 mb-1">Total Dû</div>
                <div class="text-xl font-bold text-indigo-600 dark:text-indigo-400">{{ total_du|number_format(0, ',', ' ') }} GNF</div>
            </div>
        </div>

        {# Filtres #}
        <div class="flex flex-wrap gap-2 mb-6">
            <a href="{{ path('app_paiement_index') }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition {{ not current_statut ? 'bg-indigo-600 text-white' : 'bg-white dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 shadow-sm' }}">
                Tous
            </a>
            {% set s_colors = {'VALIDE': 'emerald', 'EN_ATTENTE': 'amber', 'PARTIEL': 'blue', 'ANNULE': 'red'} %}
            {% for s in statuts %}
            {% set color = s_colors[s.value] ?? 'slate' %}
            <a href="{{ path('app_paiement_index', {statut: s.value}) }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition shadow-sm
               {{ current_statut == s.value ? 'bg-' ~ color ~ '-600 text-white' : 'bg-white dark:bg-slate-800 text-' ~ color ~ '-700 dark:text-' ~ color ~ '-400 border border-' ~ color ~ '-200 dark:border-' ~ color ~ '-500/20' }}">
                {{ ('enum.paiement.' ~ s.value)|trans }}
            </a>
            {% endfor %}
        </div>

        {# Table #}
        <div class="rounded-2xl overflow-hidden bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/80 border-b border-slate-200 dark:border-slate-700">
                        <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Mois</th>
                        {% if app.user.role.value != 'LOCATAIRE' %}
                        <th class="text-left px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Contrat / Locataire</th>
                        {% endif %}
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Montant Dû</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Versé</th>
                        <th class="text-center px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Statut</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50">
                    {% for paiement in paiements %}
                    {% set sc_map = {'VALIDE': 'emerald', 'EN_ATTENTE': 'amber', 'PARTIEL': 'blue', 'ANNULE': 'red'} %}
                    {% set sc = sc_map[paiement.statut.value] ?? 'slate' %}
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/20 transition">
                        <td class="px-6 py-4 text-sm font-medium text-slate-900 dark:text-white flex items-center gap-2">
                            <span class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 flex items-center justify-center text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-500/20">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </span>
                            {{ paiement.mois ? paiement.mois|date('M Y')|upper : 'N/A' }}
                        </td>
                        {% if app.user.role.value != 'LOCATAIRE' %}
                        <td class="px-6 py-4">
                            <div class="text-sm font-medium text-slate-900 dark:text-white">{{ paiement.contrat ? paiement.contrat.numero : 'N/A' }}</div>
                            <div class="text-xs text-slate-400">{{ paiement.contrat ? paiement.contrat.locataire.email : '' }}</div>
                        </td>
                        {% endif %}
                        <td class="px-6 py-4 text-right text-sm text-slate-900 dark:text-white">{{ paiement.montantDu|number_format(0, ',', ' ') }}</td>
                        <td class="px-6 py-4 text-right text-sm font-medium text-emerald-600 dark:text-emerald-400">{{ paiement.montantVerse|number_format(0, ',', ' ') }}</td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-xs px-3 py-1 rounded-full font-medium bg-{{ sc }}-100 text-{{ sc }}-700 dark:bg-{{ sc }}-500/20 dark:text-{{ sc }}-400">
                                {{ paiement.statut.value }}
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('app_paiement_show', {id: paiement.id}) }}"
                                   class="text-xs px-3 py-1.5 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-500/20 transition">
                                   Voir
                                </a>
                                {% if is_granted('ROLE_COMPTABLE') and paiement.statut.value == 'EN_ATTENTE' %}
                                <form method="POST" action="{{ path('app_paiement_valider', {id: paiement.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ paiement.id) }}">
                                    <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-100 transition">
                                        ✓ Valider
                                    </button>
                                </form>
                                {% endif %}
                                {% if paiement.quittance %}
                                <a href="{{ path('app_quittance_download', {id: paiement.quittance.id}) }}"
                                   class="text-xs px-3 py-1.5 rounded-lg bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-100 transition"
                                   target="_blank">
                                   📄 Quittance
                                </a>
                                {% endif %}
                                {% if is_admin %}
                                <form method="POST" action="{{ path('app_paiement_annuler', {id: paiement.id}) }}"
                                      onsubmit="return confirm('Annuler ce paiement ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('annuler' ~ paiement.id) }}">
                                    <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-orange-50 dark:bg-orange-500/10 text-orange-600 dark:text-orange-400 hover:bg-orange-100 transition">
                                        ↩ Annuler
                                    </button>
                                </form>
                                <form method="POST" action="{{ path('app_paiement_delete', {id: paiement.id}) }}"
                                      onsubmit="return confirm('Supprimer définitivement ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ paiement.id) }}">
                                    <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-rose-50 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 hover:bg-rose-100 transition">
                                        🗑️
                                    </button>
                                </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-16 text-center">
                            <div class="text-4xl mb-3">💰</div>
                            <p class="text-slate-500 dark:text-slate-400">Aucun paiement trouvé.</p>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}