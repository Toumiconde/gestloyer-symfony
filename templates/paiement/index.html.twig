{% extends 'base.html.twig' %}

{% block title %}Paiements — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen themed-page" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
    <div class="max-w-7xl mx-auto px-4 py-8">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-white">💰 Paiements</h1>
                <p class="text-gray-400 text-sm mt-1">{{ paiements|length }} paiement{{ paiements|length > 1 ? 's' : '' }}</p>
            </div>
        </div>

        {# Totaux #}
        <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="rounded-xl p-4 text-center" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
                <div class="text-sm text-gray-400 mb-1">Total Versé</div>
                <div class="text-xl font-bold text-green-400">{{ total_verse|number_format(0, ',', ' ') }} GNF</div>
            </div>
            <div class="rounded-xl p-4 text-center" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2);">
                <div class="text-sm text-gray-400 mb-1">Solde Restant</div>
                <div class="text-xl font-bold text-red-400">{{ solde_total|number_format(0, ',', ' ') }} GNF</div>
            </div>
            <div class="rounded-xl p-4 text-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
                <div class="text-sm text-gray-400 mb-1">Total Dû</div>
                <div class="text-xl font-bold text-indigo-400">{{ total_du|number_format(0, ',', ' ') }} GNF</div>
            </div>
        </div>

        {# Filtres #}
        <div class="flex flex-wrap gap-2 mb-6">
            <a href="{{ path('app_paiement_index') }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition {% if not current_statut %}text-white{% else %}text-gray-400{% endif %}"
               style="background: {% if not current_statut %}#6366f1{% else %}rgba(255,255,255,0.08){% endif %};">Tous</a>
            {% for s in statuts %}
            {% set s_colors = {'VALIDE': '#10b981', 'EN_ATTENTE': '#f59e0b', 'PARTIEL': '#3b82f6', 'ANNULE': '#ef4444'} %}
            {% set sc = s_colors[s.value] ?? '#64748b' %}
            <a href="{{ path('app_paiement_index', {statut: s.value}) }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition"
               style="background: {% if current_statut == s.value %}{{ sc }}{% else %}{{ sc }}22{% endif %}; color: {% if current_statut == s.value %}white{% else %}{{ sc }}{% endif %};">
                {{ s.value }}
            </a>
            {% endfor %}
        </div>

        {# Table #}
        <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <table class="w-full">
                <thead>
                    <tr style="background: rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.1);">
                        <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase">Mois</th>
                        <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase">Contrat / Locataire</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-gray-400 uppercase">Montant Dû</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-gray-400 uppercase">Versé</th>
                        <th class="text-center px-6 py-4 text-xs font-semibold text-gray-400 uppercase">Statut</th>
                        <th class="text-right px-6 py-4 text-xs font-semibold text-gray-400 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for paiement in paiements %}
                    {% set s_colors = {'VALIDE': '#10b981', 'EN_ATTENTE': '#f59e0b', 'PARTIEL': '#3b82f6', 'ANNULE': '#ef4444'} %}
                    {% set sc = s_colors[paiement.statut.value] ?? '#64748b' %}
                    <tr class="border-b hover:bg-white/5 transition" style="border-color: rgba(255,255,255,0.05);">
                        <td class="px-6 py-4 text-sm font-medium text-white">
                            {{ paiement.mois ? paiement.mois|date('F Y')|capitalize : 'N/A' }}
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-white">{{ paiement.contrat ? paiement.contrat.numero : 'N/A' }}</div>
                            <div class="text-xs text-gray-400">{{ paiement.contrat ? paiement.contrat.locataire.email : '' }}</div>
                        </td>
                        <td class="px-6 py-4 text-right text-sm text-white">{{ paiement.montantDu|number_format(0, ',', ' ') }}</td>
                        <td class="px-6 py-4 text-right text-sm font-medium text-green-400">{{ paiement.montantVerse|number_format(0, ',', ' ') }}</td>
                        <td class="px-6 py-4 text-center">
                            <span class="text-xs px-3 py-1 rounded-full font-medium"
                                  style="background: {{ sc }}22; color: {{ sc }};">{{ paiement.statut.value }}</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('app_paiement_show', {id: paiement.id}) }}"
                                   class="text-xs px-3 py-1.5 rounded-lg text-blue-300"
                                   style="background: rgba(59,130,246,0.15);">Voir</a>

                                {% if is_granted('ROLE_COMPTABLE') and paiement.statut.value == 'EN_ATTENTE' %}
                                <form method="POST" action="{{ path('app_paiement_valider', {id: paiement.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ paiement.id) }}">
                                    <button type="submit" class="text-xs px-3 py-1.5 rounded-lg text-green-300"
                                            style="background: rgba(16,185,129,0.15);">✓ Valider</button>
                                </form>
                                {% endif %}

                                {% if paiement.quittance %}
                                <a href="{{ path('app_quittance_download', {id: paiement.quittance.id}) }}" 
                                   class="text-xs px-3 py-1.5 rounded-lg text-indigo-300 flex items-center gap-1"
                                   style="background: rgba(99,102,241,0.15);" target="_blank">
                                   📄 Quittance
                                </a>
                                {% endif %}

                                {% if is_admin %}
                                <form method="POST" action="{{ path('app_paiement_annuler', {id: paiement.id}) }}"
                                      onsubmit="return confirm('Annuler ce paiement ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('annuler' ~ paiement.id) }}">
                                    <button type="submit" class="text-xs px-3 py-1.5 rounded-lg text-orange-300"
                                            style="background: rgba(249,115,22,0.15);">↩ Annuler</button>
                                </form>
                                <form method="POST" action="{{ path('app_paiement_delete', {id: paiement.id}) }}"
                                      onsubmit="return confirm('Supprimer définitivement ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ paiement.id) }}">
                                    <button type="submit" class="text-xs px-3 py-1.5 rounded-lg text-red-300"
                                            style="background: rgba(239,68,68,0.15);">🗑️</button>
                                </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-16 text-center text-gray-500">
                            <div class="text-4xl mb-3">💰</div>
                            <p>Aucun paiement trouvé.</p>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
