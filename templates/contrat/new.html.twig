{% extends 'base.html.twig' %}

{% block title %}Nouveau Contrat — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen themed-page flex items-center justify-center py-12" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
    <div class="w-full max-w-2xl px-4">
        <div class="rounded-2xl p-8" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-center mb-8">
                <div class="text-5xl mb-4">📄</div>
                <h1 class="text-2xl font-bold text-white">Nouveau Contrat de Location</h1>
            </div>

            <form method="POST" action="{{ path('app_contrat_new') }}" class="space-y-5">
                <input type="hidden" name="_token" value="{{ csrf_token('contrat_new') }}">
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Bien immobilier *</label>
                        <select name="bien_id" required
                                class="w-full px-4 py-3 rounded-xl text-white text-sm"
                                style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);">
                            <option value="">— Sélectionner un bien —</option>
                            {% for bien in biens %}
                                <option value="{{ bien.id }}">{{ bien.adresse }} ({{ bien.ville ?? '' }})</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Locataire *</label>
                        <select name="locataire_id" required
                                class="w-full px-4 py-3 rounded-xl text-white text-sm"
                                style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);">
                            <option value="">— Sélectionner un locataire —</option>
                            {% for locataire in locataires %}
                                <option value="{{ locataire.id }}">{{ locataire.email }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Date de début *</label>
                        <input type="date" name="dateDebut" required
                               class="w-full px-4 py-3 rounded-xl text-white text-sm"
                               style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Date de fin <span class="text-gray-500">(optionnel)</span></label>
                        <input type="date" name="dateFin"
                               class="w-full px-4 py-3 rounded-xl text-white text-sm"
                               style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Loyer mensuel (GNF) *</label>
                        <input type="number" name="loyerMensuel" required min="0" step="0.01"
                               class="w-full px-4 py-3 rounded-xl text-white text-sm"
                               style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);"
                               placeholder="ex: 500000">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Caution (GNF) *</label>
                        <input type="number" name="caution" required min="0" step="0.01"
                               class="w-full px-4 py-3 rounded-xl text-white text-sm"
                               style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2);"
                               placeholder="ex: 1000000">
                    </div>
                </div>

                <div class="flex gap-3 pt-2">
                    <a href="{{ path('app_contrat_index') }}"
                       class="flex-1 px-4 py-3 rounded-xl text-sm font-medium text-center text-gray-300"
                       style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);">
                        Annuler
                    </a>
                    <button type="submit"
                            class="flex-1 px-4 py-3 rounded-xl text-sm font-medium text-white"
                            style="background: linear-gradient(135deg, #f59e0b, #ef4444);">
                        ✅ Créer le contrat
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
