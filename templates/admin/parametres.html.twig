<script>
    function changeRoleArchive(roleValue) {
        window.location.href = "{{ path('app_admin_parametres') }}?role=" + encodeURIComponent(roleValue);
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Sidebar navigation: smooth scroll without changing URL hash
        document.querySelectorAll('nav a[href^="#"]').forEach((link) => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const id = link.getAttribute('href')?.slice(1);
                if (!id) return;
                const el = document.getElementById(id);
                if (!el) return;
                el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });

        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            updateThemeUI('dark');
        } else {
            document.documentElement.classList.remove('dark');
            updateThemeUI('light');
        }

        // Messagerie: afficher l'input email uniquement si mode=one
        const mode = document.getElementById('admin-message-mode');
        const wrap = document.getElementById('admin-message-target-wrapper');
        function syncMessageMode() {
            if (!mode || !wrap) return;
            wrap.style.display = mode.value === 'one' ? '' : 'none';
        }
        mode?.addEventListener('change', syncMessageMode);
        syncMessageMode();
    });

    function setTheme(theme) {
        if (theme === 'dark') {
            document.documentElement.classList.add('dark');
            localStorage.theme = 'dark';
        } else {
            document.documentElement.classList.remove('dark');
            localStorage.theme = 'light';
        }
        updateThemeUI(theme);
    }

    function updateThemeUI(theme) {
        const btnLight = document.getElementById('btn-theme-light');
        const btnDark = document.getElementById('btn-theme-dark');

        if (theme === 'dark') {
            btnDark.style.borderColor = 'rgba(99,102,241,0.5)';
            btnDark.style.background = 'rgba(99,102,241,0.1)';
            btnDark.querySelector('span').classList.add('text-indigo-300');
            btnDark.querySelector('span').classList.remove('text-slate-300');
            
            btnLight.style.borderColor = 'transparent';
            btnLight.style.background = 'rgba(255,255,255,0.04)';
            btnLight.querySelector('span').classList.remove('text-amber-500');
            btnLight.querySelector('span').classList.add('text-slate-300');
        } else {
            btnLight.style.borderColor = 'rgba(245,158,11,0.5)';
            btnLight.style.background = 'rgba(245,158,11,0.1)';
            btnLight.querySelector('span').classList.add('text-amber-500');
            btnLight.querySelector('span').classList.remove('text-slate-300');
            
            btnDark.style.borderColor = 'transparent';
            btnDark.style.background = 'rgba(255,255,255,0.04)';
            btnDark.querySelector('span').classList.remove('text-indigo-300');
            btnDark.querySelector('span').classList.add('text-slate-300');
        }
    }

    function setLanguage(lang) {
        window.location.href = "/change-locale/" + lang;
    }
</script>
