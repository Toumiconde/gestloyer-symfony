{% extends 'base.html.twig' %}

{% block title %}Paramètres & Archives — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen themed-page pb-12 bg-slate-50 dark:bg-slate-950">
    
    {# En-tête Global #}
    <div class="border-b border-white/10" style="background: rgba(255,255,255,0.02);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-2xl flex items-center justify-center shadow-lg shadow-purple-500/20" style="background: linear-gradient(135deg, #8b5cf6, #6366f1);">
                        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-white tracking-tight">{{ 'settings.title'|trans }}</h1>
                        <p class="text-slate-400 text-sm mt-1">{{ 'settings.subtitle'|trans }}</p>
                    </div>
                </div>
                <div>
                    <a href="{{ path('app_admin_index') }}" class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-300 hover:text-white transition-all border border-white/10 hover:border-white/20 hover:bg-white/5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                        </svg>
                        {{ 'settings.back'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col lg:flex-row gap-8">
            
            {# Sidebar Navigation #}
            <div class="lg:w-1/4">
                <nav class="sticky top-6 flex flex-col gap-2">
                    <a href="#section-agence" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-indigo-500/20 text-indigo-400 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" /></svg>
                        </div>
                        <span class="text-sm font-medium text-white">Profil de l'Agence</span>
                    </a>
                    <a href="#section-archives" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-white/5 border border-transparent hover:border-white/10">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-800 text-slate-400 group-hover:bg-rose-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">Archives</span>
                    </a>
                    <a href="#section-collaborateurs" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-white/5 border border-transparent hover:border-white/10">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-800 text-slate-400 group-hover:bg-emerald-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.987 8.987 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">Comptables & Gestionnaires</span>
                    </a>
                    <a href="#section-messagerie" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-white/5 border border-transparent hover:border-white/10">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-800 text-slate-400 group-hover:bg-fuchsia-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15A2.25 2.25 0 012.25 17.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15A2.25 2.25 0 002.25 6.75m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.909A2.25 2.25 0 012.25 6.993V6.75" /></svg>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">Messagerie</span>
                    </a>
                    <a href="#section-historique" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-white/5 border border-transparent hover:border-white/10">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-800 text-slate-400 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m5-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">Historiques</span>
                    </a>
                    <a href="#section-apparence" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-white/5 border border-transparent hover:border-white/10">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-800 text-slate-400 group-hover:bg-sky-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">Apparence & Langue</span>
                    </a>
                    <a href="#section-about" class="group flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-white/5 border border-transparent hover:border-white/10">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-slate-800 text-slate-400 group-hover:bg-fuchsia-500 group-hover:text-white transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">À propos & Manuel</span>
                    </a>
                </nav>
            </div>

            {# Main Content Area #}
            <div class="lg:w-3/4 space-y-10">

                {# Section 1: Profil de l'Agence #}
                <div id="section-agence" class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                    <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                        <h2 class="text-lg font-bold text-white">Profil de l'Agence</h2>
                        <p class="text-sm text-slate-400 mt-1">Configurez les informations légales et visuelles de votre agence. Ces données apparaîtront sur les quittances.</p>
                    </div>
                    
                    <div class="p-6">
                        {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-5">
                                {# Informations principales #}
                                <div class="md:col-span-2 pb-4 border-b border-white/5">
                                    <h3 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4">Informations Générales</h3>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            {{ form_widget(form.nom, {'attr': {'class': 'block w-full rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-indigo-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                                        </div>
                                        <div>
                                            {{ form_label(form.logo, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            {{ form_widget(form.logo, {'attr': {'class': 'block w-full text-sm text-slate-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-indigo-500/20 file:text-indigo-300 hover:file:bg-indigo-500/30 transition cursor-pointer'}}) }}
                                        </div>
                                    </div>
                                </div>

                                {# Contact #}
                                <div class="md:col-span-2 pb-4 border-b border-white/5">
                                    <h3 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4">Coordonnées de Contact</h3>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                                </div>
                                                {{ form_widget(form.email, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-indigo-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                                            </div>
                                        </div>
                                        <div>
                                            {{ form_label(form.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                                                </div>
                                                {{ form_widget(form.telephone, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-indigo-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                                            </div>
                                        </div>
                                        <div class="md:col-span-2">
                                            {{ form_label(form.adresse, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            {{ form_widget(form.adresse, {'attr': {'class': 'block w-full rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-indigo-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);', 'rows': 3}}) }}
                                        </div>
                                    </div>
                                </div>

                                {# Informations Légales #}
                                <div class="md:col-span-2">
                                    <h3 class="text-sm font-semibold text-indigo-400 uppercase tracking-wider mb-4">Informations Légales & Bancaires</h3>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div>
                                            {{ form_label(form.siret, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>
                                                </div>
                                                {{ form_widget(form.siret, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-indigo-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                                            </div>
                                        </div>
                                        <div>
                                            {{ form_label(form.iban, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                    <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                                                </div>
                                                {{ form_widget(form.iban, {'attr': {'class': 'block w-full pl-10 rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-indigo-500', 'style': 'background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);'}}) }}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-end pt-5 border-t border-white/10 mt-6">
                                <button type="submit" class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium text-white transition-all shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0120.25 6v12A2.25 2.25 0 0118 20.25H6A2.25 2.25 0 013.75 18V6A2.25 2.25 0 016 3.75h1.5m9 0h-9" />
                                    </svg>
                                    Enregistrer le profil
                                </button>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                {# Section 2: Archives #}
                <div id="section-archives" class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                    <div class="px-6 py-5 border-b border-white/10 flex flex-col sm:flex-row sm:items-center justify-between gap-4" style="background: rgba(255,255,255,0.03);">
                        <div>
                            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                                <svg class="w-5 h-5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                                </svg>
                                {{ 'settings.archives_title'|trans }}
                            </h2>
                            <p class="text-sm text-slate-400 mt-1">{{ 'settings.archives_subtitle'|trans }}</p>
                        </div>
                        <div class="w-full sm:w-64">
                            <label for="roleSelector" class="sr-only">Filtrer par rôle</label>
                            <div class="relative">
                                <select id="roleSelector" onchange="changeRoleArchive(this.value)" class="block w-full rounded-xl pl-4 pr-10 py-2.5 text-sm text-white transition focus:outline-none focus:ring-1 focus:ring-rose-500 cursor-pointer appearance-none" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
                                    {% for role in roles %}
                                        <option value="{{ role.value }}" class="bg-slate-800" {% if selectedRole == role.value %}selected{% endif %}>
                                            {{ role.value|replace({'ROLE_': ''})|capitalize }}s
                                        </option>
                                    {% endfor %}
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-400">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                            <thead>
                                <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                                    <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">{{ 'settings.col_email'|trans }}</th>
                                    <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">{{ 'settings.col_date'|trans }}</th>
                                    <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">{{ 'settings.col_status'|trans }}</th>
                                    <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                                {% for archive in archives %}
                                <tr class="transition-colors hover:bg-white/[0.02]">
                                    <td class="whitespace-nowrap py-4 pl-6 pr-3">
                                        <div class="flex items-center">
                                            <div class="h-9 w-9 flex-shrink-0 rounded-xl flex items-center justify-center text-slate-400 font-bold" style="background: rgba(255,255,255,0.06);">
                                                {{ archive.email|first|upper }}
                                            </div>
                                            <div class="ml-4 font-medium text-white">{{ archive.email }}</div>
                                        </div>
                                    </td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500">{{ archive.createdAt|date('d/m/Y') }}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm">
                                        <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium text-rose-400" style="background: rgba(244,63,94,0.1); border: 1px solid rgba(244,63,94,0.2);">
                                            <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> Archivé
                                        </span>
                                    </td>
                                    <td class="relative whitespace-nowrap py-4 pl-3 pr-6 text-right text-sm font-medium">
                                        <form action="{{ path('app_admin_user_toggle', {id: archive.id}) }}" method="post" class="inline-block">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ archive.id) }}">
                                            <button type="submit" class="inline-flex items-center gap-1.5 text-indigo-400 hover:text-white px-3 py-1.5 rounded-lg transition-colors border border-indigo-500/30 hover:border-indigo-400/50 hover:bg-indigo-500/20" style="background: rgba(99,102,241,0.1);">
                                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>
                                                Réactiver
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="4" class="py-12 text-center">
                                        <div class="flex flex-col items-center justify-center gap-3">
                                            <div class="w-14 h-14 rounded-2xl flex items-center justify-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                                                <svg class="w-7 h-7 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m6 4.125l2.25 2.25m0 0l2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
                                            </div>
                                            <p class="text-sm font-medium text-white">Aucune archive</p>
                                            <p class="text-sm text-slate-500">Aucun utilisateur inactif pour ce rôle.</p>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {# Section 3: Collaborateurs (Comptables & Gestionnaires) #}
                <div id="section-collaborateurs" class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                    <div class="px-6 py-5 border-b border-white/10 flex flex-col sm:flex-row sm:items-center justify-between gap-4" style="background: rgba(255,255,255,0.03);">
                        <div>
                            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                                <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.987 8.987 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Comptables & Gestionnaires
                            </h2>
                            <p class="text-sm text-slate-400 mt-1">Vue d'ensemble des collaborateurs clés qui traitent les opérations (contrats, paiements, incidents).</p>
                        </div>
                        <div class="flex flex-col sm:flex-row gap-2">
                            <a href="{{ path('app_admin_users', {role: 'ROLE_GESTIONNAIRE'}) }}"
                               class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-300 hover:text-white transition-all border border-white/10 hover:border-white/20 hover:bg-white/5">
                                Voir gestionnaires
                            </a>
                            <a href="{{ path('app_admin_users', {role: 'ROLE_COMPTABLE'}) }}"
                               class="inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-300 hover:text-white transition-all border border-white/10 hover:border-white/20 hover:bg-white/5">
                                Voir comptables
                            </a>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="min-w-full">
                            <thead>
                                <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                                    <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Email</th>
                                    <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Rôle</th>
                                    <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Statut</th>
                                    <th class="py-3 pl-3 pr-6 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Action</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                                {% for u in collaborateurs %}
                                    <tr class="transition-colors hover:bg-white/[0.02]">
                                        <td class="whitespace-nowrap py-4 pl-6 pr-3">
                                            <div class="flex items-center">
                                                <div class="h-9 w-9 flex-shrink-0 rounded-xl flex items-center justify-center text-slate-400 font-bold" style="background: rgba(255,255,255,0.06);">
                                                    {{ u.email|first|upper }}
                                                </div>
                                                <div class="ml-4 font-medium text-white">{{ u.email }}</div>
                                            </div>
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-300">{{ u.role.value|replace({'ROLE_': ''})|capitalize }}</td>
                                        <td class="whitespace-nowrap px-3 py-4 text-sm">
                                            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium text-emerald-300" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Actif
                                            </span>
                                        </td>
                                        <td class="whitespace-nowrap py-4 pl-3 pr-6 text-right text-sm font-medium">
                                            <a href="{{ path('app_admin_user_edit', {id: u.id}) }}"
                                               class="inline-flex items-center gap-1.5 text-indigo-400 hover:text-white px-3 py-1.5 rounded-lg transition-colors border border-indigo-500/30 hover:border-indigo-400/50 hover:bg-indigo-500/20"
                                               style="background: rgba(99,102,241,0.1);">
                                                Gérer
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="py-10 text-center text-slate-500">
                                            Aucun collaborateur actif (gestionnaire/comptable) pour le moment.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                {# Section 4: Messagerie (diffusion / par personne / locataires en retard) #}
                <div id="section-messagerie" class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                    <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                        <h2 class="text-lg font-bold text-white">Messagerie</h2>
                        <p class="text-sm text-slate-400 mt-1">Envoyer un message à tous, à une personne, ou au groupe des locataires en retard de paiement.</p>
                    </div>
                    <div class="p-6">
                        <form method="POST" action="{{ path('app_admin_parametres_send_message') }}" class="space-y-4">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_send_message') }}">

                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div class="md:col-span-1">
                                    <label class="block text-sm font-medium text-slate-300 mb-2">Cible</label>
                                    <select name="mode" id="admin-message-mode"
                                            class="block w-full rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-fuchsia-500"
                                            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
                                        <option value="all_locataires">Diffusion totale (tous les locataires)</option>
                                        <option value="one">Par personne (email)</option>
                                        <option value="late_locataires">Groupe (locataires en retard de paiement)</option>
                                    </select>
                                </div>

                                <div class="md:col-span-2" id="admin-message-target-wrapper" style="display:none;">
                                    <label class="block text-sm font-medium text-slate-300 mb-2">Email destinataire</label>
                                    <input type="email" name="targetEmail" placeholder="ex: locataire@exemple.com"
                                           class="block w-full rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-fuchsia-500"
                                           style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-300 mb-2">Sujet</label>
                                <input type="text" name="subject" required
                                       placeholder="Rappel de paiement / Information importante…"
                                       class="block w-full rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-fuchsia-500"
                                       style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-300 mb-2">Message</label>
                                <textarea name="body" rows="6" required
                                          placeholder="Bonjour,&#10;&#10;Merci de régulariser votre paiement avant la fin du mois…"
                                          class="block w-full rounded-xl px-4 py-2.5 text-white text-sm transition focus:outline-none focus:ring-1 focus:ring-fuchsia-500"
                                          style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);"></textarea>
                            </div>

                            <div class="flex justify-end pt-2">
                                <button type="submit"
                                        class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium text-white transition-all shadow-lg shadow-fuchsia-500/20 hover:shadow-fuchsia-500/40 hover:-translate-y-0.5"
                                        style="background: linear-gradient(135deg, #d946ef, #6366f1);">
                                    Envoyer le message
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                {# Section 3: Historiques #}
                <div id="section-historique" class="space-y-8">
                    <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
                        <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                            <h2 class="text-lg font-bold text-white">Historique des connexions / déconnexions</h2>
                            <p class="text-sm text-slate-400 mt-1">Suivi des utilisateurs qui se connectent et se déconnectent.</p>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="min-w-full">
                                <thead>
                                    <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                                        <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Utilisateur</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Action</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">IP</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                                    {% for item in recentConnections %}
                                        <tr class="transition-colors hover:bg-white/[0.02] cursor-pointer"
                                            onclick="window.location.href='{{ path('app_admin_history_show', {id: item.id}) }}'">
                                            <td class="py-3 pl-6 pr-3 text-sm text-slate-300">{{ item.createdAt|date('d/m/Y H:i:s') }}</td>
                                            <td class="px-3 py-3 text-sm text-white">{{ item.actorEmail ?? 'N/A' }}</td>
                                            <td class="px-3 py-3 text-xs text-indigo-300">{{ item.action }}</td>
                                            <td class="px-3 py-3 text-sm text-slate-400">{{ item.ipAddress ?? '-' }}</td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="4" class="py-8 text-center text-slate-500">Aucun historique de connexion pour le moment.</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
                        <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                            <h2 class="text-lg font-bold text-white">Historique des actions utilisateurs</h2>
                            <p class="text-sm text-slate-400 mt-1">Qui a fait quoi dans l'administration.</p>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="min-w-full">
                                <thead>
                                    <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                                        <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Acteur</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Action</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Cible</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Détails</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                                    {% for item in recentUserActions %}
                                        <tr class="transition-colors hover:bg-white/[0.02] cursor-pointer"
                                            onclick="window.location.href='{{ path('app_admin_history_show', {id: item.id}) }}'">
                                            <td class="py-3 pl-6 pr-3 text-sm text-slate-300">{{ item.createdAt|date('d/m/Y H:i:s') }}</td>
                                            <td class="px-3 py-3 text-sm text-white">{{ item.actorEmail ?? 'N/A' }}</td>
                                            <td class="px-3 py-3 text-xs text-emerald-300">{{ item.action }}</td>
                                            <td class="px-3 py-3 text-sm text-slate-300">{{ item.targetEmail ?? '-' }}</td>
                                            <td class="px-3 py-3 text-sm text-slate-400">{{ item.details ?? '-' }}</td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="5" class="py-8 text-center text-slate-500">Aucune action enregistrée pour le moment.</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
                        <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                            <h2 class="text-lg font-bold text-white">Historique imports / exports CSV</h2>
                            <p class="text-sm text-slate-400 mt-1">Traçabilité des imports et exports de rapports CSV.</p>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="min-w-full">
                                <thead>
                                    <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                                        <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Utilisateur</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Action CSV</th>
                                        <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Détails</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                                    {% for item in recentCsvHistory %}
                                        <tr class="transition-colors hover:bg-white/[0.02] cursor-pointer"
                                            onclick="window.location.href='{{ path('app_admin_history_show', {id: item.id}) }}'">
                                            <td class="py-3 pl-6 pr-3 text-sm text-slate-300">{{ item.createdAt|date('d/m/Y H:i:s') }}</td>
                                            <td class="px-3 py-3 text-sm text-white">{{ item.actorEmail ?? 'N/A' }}</td>
                                            <td class="px-3 py-3 text-xs text-fuchsia-300">{{ item.action }}</td>
                                            <td class="px-3 py-3 text-sm text-slate-400">{{ item.details ?? '-' }}</td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="4" class="py-8 text-center text-slate-500">Aucun import/export CSV pour le moment.</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                {# Section 3: Apparence & Langue #}
                <div id="section-apparence" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    
                    {# Apparence #}
                    <div class="rounded-2xl p-6" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                        <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                            <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
                            </svg>
                            Apparence du panel
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <button onclick="setTheme('light')" id="btn-theme-light" class="group relative flex flex-col items-center justify-center p-5 rounded-xl border-2 transition-all" style="background: rgba(255,255,255,0.04); border-color: transparent;">
                                <div class="w-12 h-12 rounded-full flex items-center justify-center mb-3 shadow-lg" style="background: #f8fafc;">
                                    <svg class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
                                </div>
                                <span class="text-sm font-semibold text-slate-300 group-hover:text-white transition-colors">Thème Clair</span>
                            </button>
                            <button onclick="setTheme('dark')" id="btn-theme-dark" class="group relative flex flex-col items-center justify-center p-5 rounded-xl border-2 transition-all" style="background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.5);">
                                <div class="w-12 h-12 rounded-full flex items-center justify-center mb-3 shadow-lg" style="background: #0f172a; border: 1px solid rgba(255,255,255,0.1);">
                                    <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
                                </div>
                                <span class="text-sm font-semibold text-indigo-300">Thème Sombre</span>
                            </button>
                        </div>
                    </div>

                    {# Langue #}
                    <div class="rounded-2xl p-6" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
