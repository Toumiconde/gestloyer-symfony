{% extends 'base.html.twig' %}

{% block title %}Détail Historique | Admin{% endblock %}

{% block body %}
<div class="themed-page min-h-screen pb-12 bg-slate-50 dark:bg-slate-950">
    <div class="border-b border-white/10" style="background: rgba(255,255,255,0.02);">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-white">Détail historique</h1>
                    <p class="text-sm text-slate-400 mt-1">
                        Session: {{ sessionId ?? 'N/A' }} — {{ root.actorEmail ?? 'N/A' }}
                    </p>
                </div>
                <a href="{{ path('app_admin_parametres') }}#section-historique"
                   class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-300 hover:text-white transition-all border border-white/10 hover:border-white/20 hover:bg-white/5">
                    ← Retour
                </a>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);">
            <div class="px-6 py-5 border-b border-white/10" style="background: rgba(255,255,255,0.03);">
                <h2 class="text-lg font-bold text-white">Actions réalisées</h2>
                <p class="text-sm text-slate-400 mt-1">Toutes les actions (POST/PUT/PATCH/DELETE) + login/logout et opérations importantes.</p>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead>
                        <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Action</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Route</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Méthode</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Détails</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                        {% for item in items %}
                            <tr class="transition-colors hover:bg-white/[0.02]">
                                <td class="py-3 pl-6 pr-3 text-sm text-slate-300">{{ item.createdAt|date('d/m/Y H:i:s') }}</td>
                                <td class="px-3 py-3 text-xs text-indigo-300">{{ item.action }}</td>
                                <td class="px-3 py-3 text-sm text-slate-300">{{ item.route ?? '-' }}</td>
                                <td class="px-3 py-3 text-sm text-slate-400">{{ item.method ?? '-' }}</td>
                                <td class="px-3 py-3 text-sm text-slate-400">
                                    {{ item.details ?? '-' }}
                                    {% if item.url %}
                                        <div class="text-xs text-slate-500 mt-1 break-all">{{ item.url }}</div>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="py-10 text-center text-slate-500">Aucune action trouvée pour cette session.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

