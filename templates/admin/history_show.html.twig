{% extends 'base.html.twig' %}

{% block title %}Détail Historique | Admin{% endblock %}

{% block body %}
<div class="themed-page min-h-screen pb-12 bg-slate-50 dark:bg-slate-50 dark:bg-slate-950">
    <div class="border-b border-slate-200 dark:border-white/10 bg-white dark:bg-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Historique Utilisateur</h1>
                    <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
                        Toutes les actions récentes de : <strong class="text-indigo-400">{{ root.actorEmail ?? 'Utilisateur inconnu' }}</strong>
                    </p>
                </div>
                <a href="{{ path('app_admin_parametres') }}#section-historique"
                   class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-white transition-all border border-slate-200 dark:border-white/10 hover:border-slate-300 dark:border-white/20 hover:bg-slate-100 dark:hover:bg-slate-100 dark:bg-white/5">
                    ← Retour
                </a>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="rounded-2xl overflow-hidden bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="px-6 py-5 border-b border-slate-200 dark:border-white/10 bg-white dark:bg-slate-800">
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Actions réalisées par cet utilisateur</h2>
                <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Les 100 dernières actions (connexions, modifications, ajouts, suppressions) associées à cet email.</p>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead>
                        <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08);">
                            <th class="py-3 pl-6 pr-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Action</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Route</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Méthode</th>
                            <th class="px-3 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Détails</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y" style="divide-color: rgba(255,255,255,0.05);">
                        {% for item in items %}
                            <tr class="transition-colors hover:bg-white/[0.02]">
                                <td class="py-3 pl-6 pr-3 text-sm text-slate-700 dark:text-slate-300">{{ item.createdAt|date('d/m/Y H:i:s') }}</td>
                                <td class="px-3 py-3 text-xs text-indigo-300">{{ item.action }}</td>
                                <td class="px-3 py-3 text-sm text-slate-700 dark:text-slate-300">{{ item.route ?? '-' }}</td>
                                <td class="px-3 py-3 text-sm text-slate-600 dark:text-slate-400">{{ item.method ?? '-' }}</td>
                                <td class="px-3 py-3 text-sm text-slate-600 dark:text-slate-400">
                                    {{ item.details ?? '-' }}
                                    {% if item.url %}
                                        <div class="text-xs mt-1 break-all">
                                            <a href="{{ item.url }}" target="_blank" class="text-indigo-400 hover:text-indigo-300 hover:underline transition-colors flex items-center gap-1 inline-flex">
                                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                                                {{ item.url }}
                                            </a>
                                        </div>
                                    {% endif %}
                                    {% if item.payload %}
                                        <details class="mt-2 text-xs group">
                                            <summary class="cursor-pointer inline-flex items-center gap-1 text-slate-700 dark:text-slate-300 hover:text-white transition-colors bg-slate-100 dark:bg-white/5 hover:bg-white/10 px-2 py-1 rounded-md border border-slate-200 dark:border-white/10 select-none">
                                                <svg class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                                                Voir les données
                                            </summary>
                                            <div class="mt-2 p-3 rounded-lg bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-white/5 overflow-x-auto">
                                                <table class="w-full text-left">
                                                    {% for key, value in item.payload %}
                                                        <tr class="border-b border-slate-200 dark:border-white/5 last:border-0">
                                                            <td class="py-1 pr-4 font-medium text-slate-600 dark:text-slate-400">{{ key }}</td>
                                                            <td class="py-1 text-slate-700 dark:text-slate-300 break-all font-mono">
                                                                {% if value is iterable %}
                                                                    {{ value|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE'))|nl2br }}
                                                                {% else %}
                                                                    {{ value }}
                                                                {% endif %}
                                                            </td>
                                                        </tr>
                                                    {% endfor %}
                                                </table>
                                            </div>
                                        </details>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="py-10 text-center text-slate-500">Aucune action trouvée pour cette session.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

