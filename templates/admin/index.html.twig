{% extends 'base.html.twig' %}

{% block title %}Panel Admin — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen themed-page bg-slate-50 dark:bg-slate-950">

    {# Decorative glow #}
    <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden">
        <div class="absolute -top-40 left-1/3 w-[600px] h-[600px] rounded-full opacity-[0.04]" style="background: radial-gradient(circle, #6366f1 0%, transparent 70%);"></div>
        <div class="absolute top-20 right-10 w-[400px] h-[400px] rounded-full opacity-[0.03]" style="background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-16">

        {# ── PAGE HEADER ─────────────────────────────────────────── #}
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shadow-lg" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                        </svg>
                    </div>
                    <h1 class="text-3xl font-bold text-white tracking-tight">{{ 'admin.title'|trans }}</h1>
                </div>
                <p class="text-slate-400 text-sm ml-13">{{ 'admin.subtitle'|trans }}</p>
            </div>
            <div class="flex gap-3">
                <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-300 hover:text-white transition-all border border-white/10 hover:border-white/20 hover:bg-white/5">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                    {{ 'admin.vue_gestionnaire'|trans }}
                </a>
                <a href="{{ path('app_admin_parametres') }}" class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-slate-300 hover:text-white transition-all border border-white/10 hover:border-indigo-400/40 hover:bg-indigo-500/10">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Paramètres
                </a>
                <button type="button" class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium text-white transition-all shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                    {{ 'admin.rapport'|trans }}
                </button>
            </div>
        </div>

        {# ── KPI CARDS ────────────────────────────────────────────── #}
        <dl class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-10">
            {% set kpis = [
                {
                    label: 'admin.utilisateurs_actifs'|trans,
                    value: stats.utilisateurs_actifs,
                    sub: 'admin.sur_total'|trans({'%total%': stats.total_utilisateurs}),
                    color: '#6366f1',
                    bg: 'rgba(99,102,241,0.12)',
                    border: 'rgba(99,102,241,0.25)',
                    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z'
                },
                {
                    label: 'admin.biens'|trans,
                    value: stats.total_biens,
                    sub: 'admin.contrats'|trans ~ ': ' ~ stats.total_contrats,
                    color: '#0ea5e9',
                    bg: 'rgba(14,165,233,0.12)',
                    border: 'rgba(14,165,233,0.25)',
                    icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21'
                },
                {
                    label: 'admin.revenus'|trans,
                    value: revenus_globaux|number_format(0, ',', ' ') ~ ' GNF',
                    sub: 'admin.paiements_traites'|trans({'%count%': stats.total_paiements}),
                    color: '#10b981',
                    bg: 'rgba(16,185,129,0.12)',
                    border: 'rgba(16,185,129,0.25)',
                    icon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                },
                {
                    label: 'admin.incidents'|trans,
                    value: stats.incidents_ouverts,
                    sub: 'admin.necessitent_action'|trans,
                    color: '#f43f5e',
                    bg: 'rgba(244,63,94,0.12)',
                    border: 'rgba(244,63,94,0.25)',
                    icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z'
                }
            ] %}

            {% for kpi in kpis %}
            <div class="relative overflow-hidden rounded-2xl p-5 flex flex-col gap-3 group hover:-translate-y-1 transition-all duration-200 cursor-default"
                 style="background: rgba(255,255,255,0.03); border: 1px solid {{ kpi.border }};">
                <div class="flex items-start justify-between">
                    <div class="p-2.5 rounded-xl" style="background: {{ kpi.bg }}; border: 1px solid {{ kpi.border }};">
                        <svg class="h-5 w-5" style="color: {{ kpi.color }};" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="{{ kpi.icon }}" />
                        </svg>
                    </div>
                    <span class="text-xs font-medium px-2 py-1 rounded-full" style="background: {{ kpi.bg }}; color: {{ kpi.color }};">LIVE</span>
                </div>
                <div>
                    <p class="text-sm font-medium text-slate-400">{{ kpi.label }}</p>
                    <p class="text-2xl font-bold text-white mt-0.5">{{ kpi.value }}</p>
                    <p class="text-xs text-slate-500 mt-1">{{ kpi.sub }}</p>
                </div>
                {# Bottom accent line #}
                <div class="absolute bottom-0 left-0 right-0 h-0.5 rounded-b-2xl opacity-60" style="background: linear-gradient(90deg, transparent, {{ kpi.color }}, transparent);"></div>
            </div>
            {% endfor %}
        </dl>

        {# ── CHARTS + ACTIVITY ─────────────────────────────────────── #}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

            {# Revenue Chart #}
            <div class="lg:col-span-2 rounded-2xl p-6" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <h2 class="text-base font-semibold text-white">{{ 'admin.evolution_revenus'|trans }}</h2>
                        <p class="text-xs text-slate-500 mt-0.5">Revenus cumulés sur les 6 derniers mois</p>
                    </div>
                    <div class="flex items-center gap-2 text-xs font-medium text-emerald-400 px-3 py-1.5 rounded-full" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        {{ 'admin.en_direct'|trans }}
                    </div>
                </div>
                <div class="h-72 w-full">
                    <canvas id="adminRevenueChart"></canvas>
                </div>
            </div>

            {# Activity Feed #}
            <div class="rounded-2xl p-6 flex flex-col" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
                <h2 class="text-base font-semibold text-white mb-5">{{ 'admin.activite_recente'|trans }}</h2>

                <div class="flex-1 space-y-5 overflow-y-auto pr-1 custom-scrollbar">

                    {# Incidents #}
                    <div>
                        <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 mb-3">{{ 'admin.derniers_incidents'|trans }}</p>
                        <ul class="space-y-2">
                            {% for incident in derniers_incidents %}
                            <li class="flex items-start gap-3 p-3 rounded-xl transition-colors" style="background: rgba(244,63,94,0.06); border: 1px solid rgba(244,63,94,0.12);">
                                <div class="mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(244,63,94,0.15);">
                                    <svg class="w-3.5 h-3.5 text-rose-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-medium text-white truncate">{{ incident.titre|default('Incident') }}</p>
                                    <p class="text-[10px] text-slate-500 mt-0.5">{{ incident.createdAt|date('d/m H:i') }}</p>
                                </div>
                            </li>
                            {% else %}
                            <li class="text-xs text-slate-600 italic py-2 text-center">Aucun incident récent</li>
                            {% endfor %}
                        </ul>
                    </div>

                    {# Paiements #}
                    <div>
                        <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 mb-3">{{ 'admin.derniers_paiements'|trans }}</p>
                        <ul class="space-y-2">
                            {% for paiement in derniers_paiements %}
                            <li class="flex items-start gap-3 p-3 rounded-xl" style="background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.12);">
                                <div class="mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(16,185,129,0.15);">
                                    <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                                    </svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-semibold text-emerald-400">+{{ paiement.montantVerse|number_format(0, ',', ' ') }} GNF</p>
                                    <p class="text-[10px] text-slate-500 truncate mt-0.5">{{ paiement.contrat.bien.nom|default('Contrat') }}</p>
                                </div>
                                <span class="text-[10px] text-slate-600 whitespace-nowrap">{{ paiement.mois|date('m/Y') }}</span>
                            </li>
                            {% else %}
                            <li class="text-xs text-slate-600 italic py-2 text-center">Aucun paiement récent</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        {# ── QUICK ACTIONS + ROLE DISTRIBUTION ──────────────────── #}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            {# Quick Actions #}
            <div class="rounded-2xl p-6" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
                <h2 class="text-base font-semibold text-white mb-5">{{ 'admin.gestion_rapide'|trans }}</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">

                    {% set shortcuts = [
                        { href: path('app_admin_users'), label: 'admin.utilisateurs'|trans, color: '#6366f1', bg: 'rgba(99,102,241,0.12)', border: 'rgba(99,102,241,0.25)', icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z' },
                        { href: path('app_bien_index'), label: 'menu.patrimoine'|trans, color: '#0ea5e9', bg: 'rgba(14,165,233,0.12)', border: 'rgba(14,165,233,0.25)', icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21' },
                        { href: path('app_contrat_index'), label: 'menu.contrats'|trans, color: '#f59e0b', bg: 'rgba(245,158,11,0.12)', border: 'rgba(245,158,11,0.25)', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z' },
                        { href: path('app_incident_index'), label: 'admin.incidents_btn'|trans, color: '#f43f5e', bg: 'rgba(244,63,94,0.12)', border: 'rgba(244,63,94,0.25)', icon: 'M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0' },
                        { href: path('app_paiement_index'), label: 'menu.paiements'|trans, color: '#10b981', bg: 'rgba(16,185,129,0.12)', border: 'rgba(16,185,129,0.25)', icon: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z' },
                        { href: path('app_admin_parametres'), label: 'settings.title'|trans, color: '#8b5cf6', bg: 'rgba(139,92,246,0.12)', border: 'rgba(139,92,246,0.25)', icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z' }
                    ] %}

                    {% for sc in shortcuts %}
                    <a href="{{ sc.href }}" class="group flex flex-col items-center justify-center gap-2.5 p-4 rounded-xl transition-all duration-200 hover:-translate-y-0.5"
                       style="background: {{ sc.bg }}; border: 1px solid {{ sc.border }};">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center transition-transform group-hover:scale-110" style="background: {{ sc.bg }}; border: 1px solid {{ sc.border }};">
                            <svg class="w-5 h-5" style="color: {{ sc.color }};" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="{{ sc.icon }}" />
                            </svg>
                        </div>
                        <span class="text-xs font-semibold text-center" style="color: {{ sc.color }};">{{ sc.label }}</span>
                    </a>
                    {% endfor %}
                </div>
            </div>

            {# Role Distribution #}
            <div class="rounded-2xl p-6" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
                <h2 class="text-base font-semibold text-white mb-5">{{ 'admin.repartition'|trans }}</h2>
                <div class="space-y-4">
                    {% set role_labels = {
                        'ROLE_ADMIN':         { label: 'role.administrateurs'|trans, color: '#6366f1' },
                        'ROLE_GESTIONNAIRE':  { label: 'role.gestionnaires'|trans,  color: '#0ea5e9' },
                        'ROLE_COMPTABLE':     { label: 'role.comptables'|trans,     color: '#10b981' },
                        'ROLE_PROPRIETAIRE':  { label: 'role.proprietaires'|trans,  color: '#f59e0b' },
                        'ROLE_LOCATAIRE':     { label: 'role.locataires'|trans,     color: '#f43f5e' }
                    } %}

                    {% for roleValue, count in par_role %}
                        {% set info = role_labels[roleValue] ?? { label: roleValue, color: '#64748b' } %}
                        {% set percentage = stats.total_utilisateurs > 0 ? (count / stats.total_utilisateurs * 100)|round : 0 %}
                        <div>
                            <div class="flex items-center justify-between text-sm mb-2">
                                <div class="flex items-center gap-2">
                                    <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background: {{ info.color }};"></div>
                                    <span class="font-medium text-slate-300">{{ info.label }}</span>
                                </div>
                                <span class="text-white font-semibold tabular-nums">{{ count }} <span class="text-slate-500 font-normal text-xs">({{ percentage }}%)</span></span>
                            </div>
                            <div class="w-full rounded-full h-1.5 overflow-hidden" style="background: rgba(255,255,255,0.06);">
                                <div class="h-1.5 rounded-full transition-all duration-700" style="width: {{ percentage }}%; background: {{ info.color }};"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

    </div>
</div>

<style>
.custom-scrollbar::-webkit-scrollbar { width: 3px; }
.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('adminRevenueChart');
            if (!ctx) return;
            const isDark = true;
            let gradient = ctx.getContext('2d').createLinearGradient(0, 0, 0, 350);
            gradient.addColorStop(0, 'rgba(99,102,241,0.3)');
            gradient.addColorStop(1, 'rgba(99,102,241,0.0)');

            const base = {{ revenus_globaux > 0 ? revenus_globaux / 6 : 25000000 }};
            const data = [base*0.65, base*0.8, base*0.75, base*1.1, base*0.95, base];

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin'],
                    datasets: [{
                        label: 'Revenus (GNF)',
                        data: data,
                        borderColor: '#6366f1',
                        backgroundColor: gradient,
                        borderWidth: 2.5,
                        pointBackgroundColor: '#0f172a',
                        pointBorderColor: '#6366f1',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(2,6,23,0.95)',
                            titleColor: '#f8fafc',
                            bodyColor: '#94a3b8',
                            borderColor: 'rgba(99,102,241,0.3)',
                            borderWidth: 1,
                            padding: 12,
                            displayColors: false,
                            callbacks: {
                                label: c => new Intl.NumberFormat('fr-FR').format(c.parsed.y) + ' GNF'
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },
                            ticks: { color: '#475569', callback: v => (v/1000000).toFixed(0) + 'M' }
                        },
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: { color: '#475569' }
                        }
                    },
                    interaction: { intersect: false, mode: 'index' }
                }
            });
        });
    </script>
{% endblock %}
