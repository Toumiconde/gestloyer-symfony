{% extends 'base.html.twig' %}

{% block title %}Incidents — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen pb-12 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 py-8">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white">🔔 Incidents & Signalements</h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">{{ incidents|length }} incident{{ incidents|length > 1 ? 's' : '' }}</p>
            </div>
            {% if not is_granted('ROLE_PROPRIETAIRE') %}
            <a href="{{ path('app_incident_new') }}"
               class="px-4 py-2 rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 transition shadow-lg">
                + Déclarer un incident
            </a>
            {% endif %}
        </div>

        {# Filtres Statut #}
        <div class="flex flex-wrap gap-2 mb-3">
            <a href="{{ path('app_incident_index') }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition {{ not current_statut and not current_priorite ? 'bg-indigo-600 text-white' : 'bg-white dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700' }}">
               Tous
            </a>
            {% set sc_map = {'DECLARE': 'amber', 'EN_COURS': 'blue', 'DEVIS_SOUMIS': 'purple', 'APPROUVE': 'sky', 'RESOLU': 'emerald', 'CLOTURE': 'slate'} %}
            {% for s in statuts %}
            {% set color = sc_map[s.value] ?? 'slate' %}
            <a href="{{ path('app_incident_index', {statut: s.value, priorite: current_priorite}) }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition
               {{ current_statut == s.value ? 'bg-' ~ color ~ '-600 text-white' : 'bg-white dark:bg-slate-800 text-' ~ color ~ '-600 dark:text-' ~ color ~ '-400 border border-' ~ color ~ '-200 dark:border-' ~ color ~ '-500/30' }}">
                {{ s.value }}
            </a>
            {% endfor %}
        </div>

        {# Filtres Priorité #}
        <div class="flex flex-wrap gap-2 mb-6">
            {% set pc_map = {'URGENT': 'red', 'NORMAL': 'amber', 'FAIBLE': 'emerald'} %}
            {% for p in priorites %}
            {% set color = pc_map[p.value] ?? 'slate' %}
            <a href="{{ path('app_incident_index', {statut: current_statut, priorite: p.value}) }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition
               {{ current_priorite == p.value ? 'bg-' ~ color ~ '-600 text-white' : 'bg-white dark:bg-slate-800 text-' ~ color ~ '-600 dark:text-' ~ color ~ '-400 border border-' ~ color ~ '-200 dark:border-' ~ color ~ '-500/30' }}">
                {{ p.value }}
            </a>
            {% endfor %}
            {% if current_statut or current_priorite %}
            <a href="{{ path('app_incident_index') }}"
               class="px-3 py-1.5 text-xs text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition">
               ✕ Effacer filtres
            </a>
            {% endif %}
        </div>

        {# Liste incidents #}
        <div class="space-y-3">
            {% for incident in incidents %}
            {% set sc_map = {'DECLARE': 'amber', 'EN_COURS': 'blue', 'DEVIS_SOUMIS': 'purple', 'APPROUVE': 'sky', 'RESOLU': 'emerald', 'CLOTURE': 'slate'} %}
            {% set pc_map = {'URGENT': 'red', 'NORMAL': 'amber', 'FAIBLE': 'emerald'} %}
            {% set sc = sc_map[incident.statut.value] ?? 'slate' %}
            {% set pc = pc_map[incident.priorite.value] ?? 'slate' %}

            <div class="rounded-2xl p-5 flex items-center justify-between bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg flex-shrink-0 bg-{{ pc }}-100 dark:bg-{{ pc }}-500/20">
                        {% if incident.priorite.value == 'URGENT' %}🚨{% elseif incident.priorite.value == 'NORMAL' %}⚠️{% else %}ℹ️{% endif %}
                    </div>
                    <div>
                        <div class="text-sm font-bold text-slate-900 dark:text-white">{{ incident.titre }}</div>
                        <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                            🏢 {{ incident.bien ? incident.bien.adresse : 'N/A' }}
                            · 👤 {{ incident.declarant ? incident.declarant.email : 'N/A' }}
                        </div>
                        <div class="text-xs text-slate-400 mt-0.5">
                            {{ incident.dateDeclaration ? incident.dateDeclaration|date('d/m/Y H:i') : '?' }}
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-xs px-2 py-1 rounded-full font-medium bg-{{ pc }}-100 dark:bg-{{ pc }}-500/20 text-{{ pc }}-700 dark:text-{{ pc }}-400">
                        {{ incident.priorite.value }}
                    </span>
                    <span class="text-xs px-2 py-1 rounded-full font-medium bg-{{ sc }}-100 dark:bg-{{ sc }}-500/20 text-{{ sc }}-700 dark:text-{{ sc }}-400">
                        {{ incident.statut.value }}
                    </span>
                    <a href="{{ path('app_incident_show', {id: incident.id}) }}"
                       class="text-sm px-3 py-2 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-100 transition">
                       Voir
                    </a>

                    {# Propriétaire : approuver/rejeter devis #}
                    {% if is_granted('ROLE_PROPRIETAIRE') and incident.statut.value == 'DEVIS_SOUMIS' %}
                        {% for devis in incident.devis %}
                        {% if devis.statut == 'SOUMIS' %}
                        <form method="POST" action="{{ path('app_devis_approuver', {id: devis.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('approuver' ~ devis.id) }}">
                            <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-100 transition">
                                ✓ Approuver devis
                            </button>
                        </form>
                        <form method="POST" action="{{ path('app_devis_rejeter', {id: devis.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('rejeter' ~ devis.id) }}">
                            <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-rose-50 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 hover:bg-rose-100 transition">
                                ✕ Rejeter
                            </button>
                        </form>
                        {% endif %}
                        {% endfor %}
                    {% endif %}

                    {% if is_admin %}
                    <form method="POST" action="{{ path('app_incident_delete', {id: incident.id}) }}"
                          onsubmit="return confirm('Supprimer cet incident ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ incident.id) }}">
                        <button type="submit" class="text-sm px-3 py-2 rounded-lg bg-rose-50 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 hover:bg-rose-100 transition">
                            🗑️
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
            {% else %}
            <div class="text-center py-20 text-slate-400">
                <div class="text-5xl mb-4">✅</div>
                <p class="text-lg">Aucun incident enregistré.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}