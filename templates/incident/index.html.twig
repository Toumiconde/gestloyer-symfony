{% extends 'base.html.twig' %}

{% block title %}Incidents — GESTLOYER{% endblock %}

{% block body %}
<div class="min-h-screen themed-page" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
    <div class="max-w-7xl mx-auto px-4 py-8">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-white">🔔 Incidents & Signalements</h1>
                <p class="text-gray-400 text-sm mt-1">{{ incidents|length }} incident{{ incidents|length > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('app_incident_new') }}"
               class="px-4 py-2 rounded-lg text-sm font-medium text-white"
               style="background: linear-gradient(135deg, #ef4444, #db2777);">
                + Déclarer un incident
            </a>
        </div>

        {# Filtres #}
        <div class="flex flex-wrap gap-2 mb-6">
            {% for s in statuts %}
            {% set s_colors = {'DECLARE': '#f59e0b', 'EN_COURS': '#3b82f6', 'DEVIS_SOUMIS': '#8b5cf6', 'APPROUVE': '#0ea5e9', 'RESOLU': '#10b981', 'CLOTURE': '#64748b'} %}
            {% set sc = s_colors[s.value] ?? '#64748b' %}
            <a href="{{ path('app_incident_index', {statut: s.value, priorite: current_priorite}) }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition"
               style="background: {% if current_statut == s.value %}{{ sc }}{% else %}{{ sc }}22{% endif %}; color: {% if current_statut == s.value %}white{% else %}{{ sc }}{% endif %};">
                {{ s.value }}
            </a>
            {% endfor %}
            <span class="text-gray-600">|</span>
            {% for p in priorites %}
            {% set p_colors = {'URGENT': '#ef4444', 'NORMAL': '#f59e0b', 'FAIBLE': '#10b981'} %}
            {% set pc = p_colors[p.value] ?? '#64748b' %}
            <a href="{{ path('app_incident_index', {statut: current_statut, priorite: p.value}) }}"
               class="px-3 py-1.5 rounded-full text-xs font-medium transition"
               style="background: {% if current_priorite == p.value %}{{ pc }}{% else %}{{ pc }}22{% endif %}; color: {% if current_priorite == p.value %}white{% else %}{{ pc }}{% endif %};">
                {{ p.value }}
            </a>
            {% endfor %}
            {% if current_statut or current_priorite %}
            <a href="{{ path('app_incident_index') }}" class="px-3 py-1.5 text-xs text-gray-500 hover:text-white">✕ Effacer</a>
            {% endif %}
        </div>

        {# Liste incidents #}
        <div class="space-y-3">
            {% for incident in incidents %}
            {% set s_colors = {'DECLARE': '#f59e0b', 'EN_COURS': '#3b82f6', 'DEVIS_SOUMIS': '#8b5cf6', 'APPROUVE': '#0ea5e9', 'RESOLU': '#10b981', 'CLOTURE': '#64748b'} %}
            {% set p_colors = {'URGENT': '#ef4444', 'NORMAL': '#f59e0b', 'FAIBLE': '#10b981'} %}
            {% set sc = s_colors[incident.statut.value] ?? '#64748b' %}
            {% set pc = p_colors[incident.priorite.value] ?? '#64748b' %}

            <div class="rounded-xl p-5 flex items-center justify-between"
                 style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg flex-shrink-0"
                         style="background: {{ pc }}22;">
                        {% if incident.priorite.value == 'URGENT' %}🚨{% elseif incident.priorite.value == 'NORMAL' %}⚠️{% else %}ℹ️{% endif %}
                    </div>
                    <div>
                        <div class="text-sm font-bold text-white">{{ incident.titre }}</div>
                        <div class="text-xs text-gray-400 mt-0.5">
                            🏢 {{ incident.bien ? incident.bien.adresse : 'N/A' }}
                            · 👤 {{ incident.declarant ? incident.declarant.email : 'N/A' }}
                        </div>
                        <div class="text-xs text-gray-500 mt-0.5">
                            {{ incident.dateDeclaration ? incident.dateDeclaration|date('d/m/Y H:i') : '?' }}
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-xs px-2 py-1 rounded-full" style="background: {{ pc }}22; color: {{ pc }};">{{ incident.priorite.value }}</span>
                    <span class="text-xs px-2 py-1 rounded-full" style="background: {{ sc }}22; color: {{ sc }};">{{ incident.statut.value }}</span>
                    <a href="{{ path('app_incident_show', {id: incident.id}) }}"
                       class="text-sm px-3 py-2 rounded-lg text-blue-300 hover:text-white transition"
                       style="background: rgba(59,130,246,0.15);">Voir</a>
                    {% if is_admin %}
                    <form method="POST" action="{{ path('app_incident_delete', {id: incident.id}) }}"
                          onsubmit="return confirm('Supprimer cet incident ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ incident.id) }}">
                        <button type="submit" class="text-sm px-3 py-2 rounded-lg text-red-300 hover:text-white"
                                style="background: rgba(239,68,68,0.15);">🗑️</button>
                    </form>
                    {% endif %}
                </div>
            </div>
            {% else %}
            <div class="text-center py-20 text-gray-500">
                <div class="text-5xl mb-4">✅</div>
                <p class="text-lg">Aucun incident enregistré.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
